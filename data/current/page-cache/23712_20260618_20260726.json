r-width: medium; border-style: none; border-color: currentcolor; border-image: initial; background: none; filter: drop-shadow(rgb(209, 77, 179) 0px 0px 2px) drop-shadow(rgb(209, 77, 179) 0px 0px 4px); }\n.live-daily-bonus-header { display: none !important; }\n.live-daily-bonus-day { color: rgb(255, 255, 255) !important; }\n.live-daily-bonus-value { color: rgb(255, 255, 255) !important; }\ntable.bbb { margin: 0px auto 20px; width: 90%; filter: drop-shadow(rgb(209, 77, 179) 0px 0px 2px) drop-shadow(rgb(209, 77, 179) 0px 0px 4px); }\ntable.bbb th { background: rgba(209, 77, 179, 0.3); color: white; padding: 5px 0px; border-radius: 30px; }\ntable.bbb tr { font-size: 15px; text-align: center; }\ntable.bbb td { padding: 0px; }\ntable.bbb tr th:nth-of-type(1) { background: rgba(255, 255, 255, 0); color: rgb(255, 255, 255); }\n</style>\n</div>"
