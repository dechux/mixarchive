radient(top,#6ac023,#65b721);background-image:linear-gradient(top,#6ac023,#65b721);text-shadow:0 1px 1px #135e00;display:inline-block;font-size:16px;padding:8px 11px 7px 11px;margin:0;width:auto;border:solid 1px #61bc14;box-shadow:0 3px 0 #467f17;}.button-green-s:hover{text-decoration:none;background:#84d933;}.content{background:#fff;margin:0 0 20px 0;padding:0 0 1px 0;box-shadow:0 1px 1px #ccc;}.content p{padding:0 10px;margin:0 0 10px 0;}.content h1{display:none;}.content h2{font-size:16px;background:#f5f5f5;border-left:solid 8px #cece2b;padding:8px 0 8px 8px;}.content h3{padding:0 0 0 5px;margin:0;}.menu{background-color:#333;padding:5px 30px;color:white;width:100%;}</style><div style=\"max-width:480px;margin:0 auto;\">\n\n<img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/66miyawaki/ポリゴン.png\" width=\"100%\">\n\n<center>\n<img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/66miyawaki/sozai_logo-edge.png\" width=\"70%\">\n</center>\n\n<img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/66miyawaki/ポリゴンB.png\" width=\"100%\">\n<br>\n<br>\n<center>\n<div style=\"padding:5px;border:2px solid #00214B;background-color:#EB93A2;color:#fff;\"> このイベントは本選期間中も<br>\n<span style=\"color:#fff;font-size:16px;font-weight:bold;\"> すぐに参加可能</span>なイベントです!! \n</div>\n</center>\n\n<!-- 💡タブセクションはじめ -->\n<div class=\"tab-content\">\n<br>\n<br>\n\n\n<input type=\"radio\" id=\"tab1\" name=\"tab\">\n<label for=\"tab1\">　⚾️概要⚾️　</label>\n<input type=\"radio\" id=\"tab2\" name=\"tab\" checked=\"\">\n<label for=\"tab2\">　⚾️特典⚾️　</label>\n <input type=\"radio\" id=\"tab3\" name=\"tab\">\n<!--<label for=\"tab3\">　GUERRILLA　</label>  -->\n\n\n\n<!-- 💡タブセクションおわり -->\n\n<div class=\"tab-box\">\n<!-- 💡1タブの中身はじめ -->\n\n<div id=\"tabView1\">\n\n<div class=\"box1\">\n\n<div class=\"box\">\n<h3 class=\"logo\">About</h3>\n\n\n<div style=\"margin:18px 10px 26px;padding:24px 14px;background:linear-gradient(rgba(0,0,0,.68), rgba(0,0,0,.86)),\nradial-gradient(circle at top, rgba(255,255,255,.28), transparent 38%),\nlinear-gradient(135deg,#050505 0%,#1b1b1b 45%,#000 100%);border:2px solid #111;box-shadow:0 0 18px rgba(0,0,0,.35);color:#fff;text-align:center;position:relative;overflow:hidden;\">\n<center>\n<img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/66miyawaki/sozai_mikkuma.png\" width=\"60%\">\n</center>\n\n\n\n<p style=\"margin:0 0 8px;font-size:16px;letter-spacing:2px;font-weight:bold;\">\n＼ 今年もやってきた！  ／\n</p>\n<div style=\"text-shadow:0 0 8px #dc143c,\n0 0 6px #dc143c,\n0 0 4px #000120,\n0 0 2px #191B35;font-size:18px;color:#fff;\">\n\n千葉ロッテマリーンズ\n\n<div class=\"typewriter line1\">\nミクチャDAY\n</div>\n\n<div class=\"typewriter line2\" style=\"color:#fff;font-size:22px;font-weight:900;text-shadow:0 0 8px rgba(255,255,255,.45);\">\n⚾ 2026年8月25日(火) ⚾\n</div>\n\n<div class=\"typewriter line3\">\n🔥開催決定🔥\n</div>\n</div>\n<br>\n\n<center>\n<img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/66miyawaki/球場内夜 (1) (1).JPG\" width=\"100%\">\n</center>\n<br>\n<small>\nCopyright © Chiba Lotte Marines All Rights Reserved.\n</small>\n<br>\n<br>\n\n\n<!-- 赤見出し -->\n<div style=\"padding:14px 14px;background:linear-gradient(90deg,#9E002D,#CE003B);color:#fff;font-size:16px;font-weight:bold;letter-spacing:2px;text-align:center;\">\n\n開催日程 &amp; 会場\n\n</div>\n\n<!-- 中身 -->\n\n<div style=\"padding:20px 18px;background:repeating-linear-gradient(\n90deg,\n#fafafa 0px,\n#fafafa 14px,\n#f1f1f1 14px,\n#f1f1f1 16px\n);border-left:2px solid #111;border-right:2px solid #111;border-bottom:6px solid #111;\">\n\n<div style=\"padding:20px 16px;background:rgba(255,255,255,.88);border:2px solid #111;border-radius:6px;\">\n\n<div style=\"margin:0 0 18px;font-size:16px;line-height:2.1;font-weight:bold;color:#111;text-align:left;\">\n\n<span style=\"color:#CE003B;display:inline-block;width:58px;\">\n日程｜\n</span>\n\n2026年8月25日(火)<br>\n\n<span style=\"color:#CE003B;display:inline-block;width:58px;\">\n球場｜\n</span>\n\nZOZOマリンスタジアム<br>\n\n<span style=\"font-size:15px;color:#666;padding-left:62px;display:block;line-height:1.8;\">\n千葉県千葉市美浜区美浜1\n</span>\n\n<span style=\"padding-left:62px;display:block;margin-top:6px;\">\n[ <a href=\"https://www.marines.co.jp/stadium/access/\" style=\"color:#CE003B;font-weight:bold;text-decoration:none;border-bottom:1px solid #CE003B;\" target=\"_blank\" referrerpolicy=\"no-referrer\">\nMAP\n</a> ]\n</span>\n\n<br>\n\n<span style=\"color:#CE003B;display:inline-block;width:58px;\">\n対戦｜\n</span>\n\n福岡ソフトバンクホークス\n\n<p></p>\n\n<p style=\"margin:0;font-size:15px;line-height:1.8;color:#666;\">\n※天災・その他球団都合等により、日程が変更となる場合がございます。\n</p>\n</div>\n</div>\n</div>\n\n<p style=\"margin:24px 0 6px;font-size:16px;font-weight:bold;line-height:1.8;\">\nこの夏、<br>\n\nZOZOマリンスタジアムを彩るのは\n<br>\n<span style=\"color:#ff4d78;font-size:22px;\">あなた</span>!!\n</p>\n\n<p></p></div>\n</div><p></p>\n\n<div class=\"box\">\n<h3 class=\"logo\">AUDITION EVENT</h3>\n\n<center>\n<img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/66miyawaki/KV_ミクチャDAY.png\" width=\"100%\">\n</center>\n\n\n\n<div style=\"margin:18px 10px 26px;padding:22px 14px;background:#fff;border:2px solid #111;box-shadow:0 4px 0 #111;color:#111;\">\n\n<div style=\"margin:0 auto 18px;padding:8px 12px;background:#111;color:#fff;text-align:center;font-size:16px;font-weight:bold;letter-spacing:2px;\">\nAUDITION SCHEDULE\n</div>\n\n<div style=\"margin:0 4px;\">\n\n<div style=\"padding:14px 0;border-bottom:1px solid #d9d9d9;\">\n<p style=\"margin:0 0 4px;color:#B81649;font-size:15px;font-weight:bold;\">EVENT❶</p>\n<p style=\"margin:0;font-size:16px;font-weight:bold;\">看板モデルオーディション</p>\n<p style=\"margin:6px 0 0;font-size:16px;\">06/13(土)12:00 -06/21(日)24:00</p>\n</div>\n\n<div style=\"padding:14px 0;border-bottom:1px solid #d9d9d9;\">\n<p style=\"margin:0 0 4px;color:#B81649;font-size:15px;font-weight:bold;\">EVENT❷</p>\n<p style=\"margin:0;font-size:16px;font-weight:bold;\">PRブースで配布!!ミクチャグッズモデルオーディション</p>\n<p style=\"margin:6px 0 0;font-size:16px;\">07/10(金)12:00 - 07/22(水) 24:00</p>\n<p style=\"margin:5px 0 0;font-size:15px;color:#CE003B;font-weight:bold;\">\n※スケジュールが変更となりましたのでご了承のうえご参加ください。\n</p>\n</div>\n\n<div style=\"padding:14px 0;border-bottom:1px solid #d9d9d9;\">\n<p style=\"margin:0 0 4px;color:#B81649;font-size:15px;font-weight:bold;\">EVENT❸</p>\n<p style=\"margin:0;font-size:16px;font-weight:bold;\">ZOZOマリンスタジアムで放映!CMモデルオーディション</p>\n<p style=\"margin:6px 0 0;font-size:16px;\">07/03(金)12:00 - 07/12(日)24:00</p>\n</div>\n\n<div style=\"padding:20px 0;text-align:center;\">\n\n<p style=\"margin:0;font-size:15px;font-weight:bold;letter-spacing:2px;color:#B81649;\">\nMORE EVENTS\n</p>\n\n<p style=\"margin:8px 0 0;font-size:22px;font-weight:900;letter-spacing:2px;color:#111;\">\nCOMING SOON...\n</p>\n\n<p style=\"margin:8px 0 0;font-size:15px;line-height:1.8;color:#666;\">\nイベントを順次公開予定⚾🔥\n</p>\n\n</div>\n\n<p></p></div><p></p>\n\n<p style=\"margin:16px 0 0;font-size:14px;line-height:1.6;color:#555;\">\n※スケジュールは変更となる場合がございます。\n</p>\n\n<p></p></div>\n</div><p></p>\n\n<div class=\"box\">\n<h3 class=\"logo\">イベントの審査基準について</h3>\n<div style=\"text-align:center;\">\n<iframe width=\"90%\" height=\"220\" src=\"https://www.youtube-nocookie.com/embed/nI804sGCn5c\" frameborder=\"0\" allow=\"accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture\" allowfullscreen=\"\"></iframe>\n</div>\n<p style=\"margin:10px;font-size:15px;\">\n<b><span class=\"point\">●</span>審査基準</b><br>\n・イベント選択して、\n<span style=\"background:linear-gradient(transparent 90%, #B81649 0%);\"><b>投稿した動画で獲得したpt</b></span>\nと\n<span style=\"background:linear-gradient(transparent 90%, #B81649 0%);\"><b>ライブ配信で獲得したpt</b></span>\nの合算からランキング入賞者に賞品をプレゼント！<br>\n<br>\n・今回のリニューアルでは投稿動画にもアイテムで応援できるようになったので、「配信する時間がなかなか取れないときに、\n<span style=\"background:linear-gradient(transparent 90%, #B81649 0%);\"><b>スキマ時間に撮った動画でアイテムを受け取る</b></span>」なんてことも出来ちゃいます🎁<br>\n<br>\n・さらにダンスや楽器演奏など場所や時間が限られるパフォーマンスだって、動画なら\n<span style=\"background:linear-gradient(transparent 90%, #B81649 0%);\"><b>いつでも投稿・視聴・応援が可能！</b></span><br>\n</p>\n<br>\n\n<p style=\"margin:10px;font-size:15px;\">\n<b><span class=\"point\">●</span>動画投稿に関しての紹介</b></p>\n<center><a class=\"link-btn\" style=\"width:170px;\" href=\"https://mixch.tv/p/obcl5stv\" target=\"_blank\" referrerpolicy=\"no-referrer\">動画投稿機能について</a></center>\n<center><a class=\"link-btn\" style=\"width:170px;\" href=\"https://mixch.tv/p/0dwekkca\" target=\"_blank\" referrerpolicy=\"no-referrer\">機能にまつわるヘルプページ</a></center>\n<p></p>\n<br>\n</div>\n\n<div class=\"box\">\n<br>\n<a href=\"https://mixch.tv/p/qjtg97sp\" target=\"_blank\" referrerpolicy=\"no-referrer\"><center><img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/koizumi/1811_kokoroe.png\" width=\"70%\"></center></a>\n\n<br>\n<div style=\"margin:10px;border:#B81649  solid 1px;display:block;padding:.2em .3em;\"><h3 style=\"border-left:#B81649  solid 6px;padding:.3em.3em.3em.8em;\">審査について</h3></div>\n\n<p style=\"margin:15px 10px;font-size:15px;\">\n<span class=\"point\">●</span>ライブ配信・動画投稿をする際は必ず<b><font color=\"#B81649\">[ 千葉ロッテマリーンズ【ミクチャDAY】 ZOZOマリンスタジアムで放映!CMモデルオーディション ]のイベント選択</font></b>をお願いします。正しく選択をしていない場合は獲得したミクチャポイントがランキングに反映されませんのでご注意ください。また、誤ってイベント選択した際にポイントを対象イベントに反映することはできかねますので予めご了承ください。<br>\n<span class=\"point\">●</span>当該ページの審査項目に沿って受賞者が決定いたします。なお、審査の過程や受賞者の決定に至った理由等につきましてはお答え出来ませんのであらかじめご了承ください。<br>\n<span class=\"point\">●</span>獲得したポイントが同一の場合は、下記の条件に従って順位を決定します。((1)から条件を適用し、順位が決定しない場合はその次の条件を適用して決定し、以下同様の処理をします。)</p>\n\n<p style=\"margin:10px 15px;font-size:14px;\">\n(1) 対象となるイベントを選択してライブ配信をした「配信時間」の合計が多いユーザーを上位とします。<br>\n(2) 対象となるイベントを選択してライブ配信をした「配信回数」の合計が多いユーザーを上位とします。<br>\n(3) 対象となるイベントを選択して行ったライブ配信・投稿動画に対して受け取った「コメント数」の合計が多いユーザーを上位とします。<br>\n(4) 対象となるイベントへの応募申し込みが早かったユーザーを上位とします。<br>\n(5) もし(1)～(5)全てが同じ場合はミクチャの「ユーザーIDの数字が小さい」ユーザーを上位とします。</p>\n\n<p style=\"margin:15px 10px;font-size:15px;\">\n※下記の注意事項も必ずお読みください。</p>\n\n<div style=\"margin:10px;border:#B81649  solid 1px;display:block;padding:.2em .3em;\"><h3 style=\"border-left:#B81649  solid 6px;padding:.3em.3em.3em.8em;\">アイテム送信に関する注意点</h3></div>\n\n<p style=\"margin:15px 10px;font-size:15px;\">\n<span class=\"point\">●</span>ライブ配信で、イベント終了間際など同時間帯に大量のアイテムを投げると、多数のアイテムリクエストによりコイン消費に遅延が生じる可能性がございます。ムービーでは遅延が生じることはないので、ムービーイベントの場合は投稿動画への積極的な送信をご検討ください。<br>\n<span class=\"point\">●</span>ライブ配信の場合、イベント期間中にライバーの端末側でアイテムのアニメーション再生が始まったアイテムはイベントのポイントに加算されます。イベント期間中に再生失敗したアイテムやイベント期間をすぎてから再生されたアイテムは、イベントのポイントに加算されません。<br>\n<span class=\"point\">●</span>なお、上記の事象が発生した場合においても、イベントへのポイント反映やコインの返却などのご対応は出来かねますのでご了承くださいませ。<br>\nそのため、ライブ配信ではできるだけ一気に大量に送るのではなく、定期的にアイテムを送るかムービーへのアイテム送信を推奨いたします。</p>\n\n<div style=\"margin:10px;border:#B81649  solid 1px;display:block;padding:.2em .3em;\"><h3 style=\"border-left:#B81649  solid 6px;padding:.3em.3em.3em.8em;\">応募規約</h3></div>\n\n<p style=\"margin:15px 10px 5px;font-size:15px;\">\n本キャンペーンに応募いただける方（以下、「応募者」といいます。）は、以下をよくお読みいただき、同意の上ご応募ください。</p>\n<p style=\"margin:5px 10px 15px;font-size:15px;\">\nミクチャにて、「イベントに参加する」をタップした時点で本規約に同意したものとみなします。万が一ご同意いただけない場合は応募を中止してください。<br>\n本規約の内容は、事前の告知なく変更される場合がありますので、予めご了承ください。</p>\n\n<div style=\"font-size:16px;padding:.75em 0;border-top:1px solid #B81649;border-bottom:1px solid #B81649;\">　▪️動画投稿・ライブ配信での注意事項</div>\n\n<p style=\"margin:15px 10px;font-size:15px;\">\n<span class=\"point\">●</span>撮影・ライブ配信が禁止されている場所または危険な場所での撮影やライブ配信はお控え下さい。<br>\n<span class=\"point\">●</span>楽曲を使用する場合は著作権者から楽曲利用の許可がおりているものをお使いください。<br>\n<span class=\"point\">●</span>大声を出す・大音量で音楽を流す、道を塞ぐなど、人の迷惑になる行為は控えて、撮影やライブ配信を実施してください。<br>\n<span class=\"point\">●</span>応募者と一緒に投稿動画・ライブ配信に写っている方がいらっしゃる場合や、第三者の知的財産権が含まれる場合、必ず投稿やライブ配信前に権利者から使用許諾を得てください。<br>\nまた、応募者は投稿動画・ライブ配信について自らが投稿・ライブ配信することについての適法な権利を有していること及び第三者の一切の権利を侵害していないことについて当社に対し表明し、保証するものとします。万が一、第三者からの権利侵害等の申し立てがあった場合には、投稿者や配信者ご自身の責任をもって解決していただきますので、予めご了承ください。<br>\n<span class=\"point\">●</span>ミクチャ以外のプラットフォームで作成した動画をミクチャでアップロードする場合、当該プラットフォームの利用規約に沿って投稿してください。<br>\n<span class=\"point\">●</span>未成年の方は保護者の同意を得た上でご応募ください。また、必要に応じて、在籍する学校または所属する部活動が加盟する連盟等へ確認をとったうえで応募してください。<br>\n<span class=\"point\">●</span>事務所、劇団、その他の団体（以下「事務所等」といいます）に所属されている方は、ご自身の責任で事務所等に本キャンペーンへの応募の可否につきご確認ください。<br>\n<span class=\"point\">●</span>コンテストなどの新しい才能の発掘を目的としたものや、事務所所属者や新グループメンバーの選定を目的とした一般的な「オーディション」に関するイベントには、キャッシュバックのお支払いはございません。なお、一部対象外のものもございますので、ご不明な場合はお問い合わせください。<br>\n<span class=\"point\">●</span>上記各項への違反や極端に他人に不快感を与えるような言動や、法律に抵触する内容、ミクチャの利用規約に違反した内容、運営事務局が不適切と判断した動画やライブ配信については削除、もしくはキャッシュバックや審査、受賞の対象外とする可能性がございますのでご了承ください。<br>\n<span class=\"point\">●</span>本応募規約に定める事項のほか、ミクチャ利用規約及びプライバシーポリシーが適用されますので、確認の上、ご応募ください。</p>\n\n<div style=\"font-size:16px;padding:.75em 0;border-top:1px solid #B81649;border-bottom:1px solid #B81649;\">　▪️賞品・受賞について</div>\n\n<p style=\"margin:15px 10px;font-size:15px;\">\n<span class=\"point\">●</span>受賞者と連絡がつかない場合、賞品受領の意思が確認できない場合、指定された期日までに連絡先をご返信いただけない場合等には、受賞を辞退されたものとみなし、受賞を無効とさせていただきます。予めご了承ください。<br>\n<span class=\"point\">●</span>受賞の権利は受賞者ご本人のものであって、第三者へ譲渡・換金等することはできません。また、受領した賞品の紛失等による再送付、受賞者の事情による変更、その他クレーム等には一切応じることができません。<br>\n<span class=\"point\">●</span>当社は、賞品の品質及び、目的適合性について何ら保証することはできかねます。賞品の使用に当たっては、賞品に記載の注意事項をご確認の上、ご使用ください。受賞された賞品の使用中に生じた事故等のトラブルについての責任は、当社では負いかねます。<br>\n<span class=\"point\">●</span>賞品提供元の何らかの事由により特典不履行となる事案が生じた場合は、代替賞品による補填などで対応することがございますのでご了承くださいませ。</p>\n\n<div style=\"font-size:16px;padding:.75em 0;border-top:1px solid #B81649;border-bottom:1px solid #B81649;\">　▪️禁止事項</div>\n\n<p style=\"margin:15px 10px 0px;font-size:15px;\">\n本キャンペーンへの応募に際し、以下の行為を禁止します。当社は、応募者が以下に該当する行為を行ったと判断した場合は、応募者への事前通告なく、対象投稿を掲載しない、掲載後削除する、応募・受賞を無効とするなどの対応をとる場合があります。</p>\n\n<p style=\"margin:10px 10px 15px;font-size:15px;\">\n・本規約または法令に違反する行為<br>\n・本キャンペーンの運営を妨げる行為<br>\n・他人に迷惑、不利益、損害または不快感を与える行為<br>\n・他人を誹謗中傷し、またはその名誉若しくは信用を毀損する行為<br>\n・第三者の著作権その他の知的財産権を侵害する行為<br>\n・他人の財産、プライバシー若しくは肖像権を侵害する行為<br>\n・わいせつ、児童ポルノ及び児童の性的搾取を助長するデータを投稿する行為<br>\n・営利を目的とした情報提供、広告宣伝もしくは勧誘行為<br>\n・公序良俗に反する行為<br>\n・ミクチャの利用規約に違反する行為<br>\n・その他、前各号に類する行為</p>\n\n<div style=\"font-size:16px;padding:.75em 0;border-top:1px solid #B81649;border-bottom:1px solid #B81649;\">　▪️免責・その他</div>\n\n<p style=\"margin:15px 10px 5px;font-size:15px;\">\n本キャンペーンは、細心の注意を払って運営をしていますが、提供する情報、プログラム、各種サービス、その他本キャンペーンに関するすべての事項について、その完全性、正確性、安全性、有用性等について、いかなる保証もするものではありません。また、利用者または第三者が被った以下の事例を含む損害については、当社は責任を負いかねます。 </p>\n\n<p style=\"margin:15px 10px 5px;font-size:15px;\">\n1.本キャンペーンへの応募に際して、ソフトウェア・ハードウェア上の事故、火災、停電、通信環境の悪化、地震、事変等の非常事態が発生した場合。<br>\n2.本キャンペーンにおけるシステムの保守を定期的あるいは緊急に行う場合。<br>\n3.利用者間または利用者と第三者の間におけるトラブル等が生じた場合。<br>\n4.第三者による本キャンペーンのサービスの妨害、情報改変などによりサービスが中断もしくは遅延し、何らかの欠陥が生じた場合。<br>\n5.当社が推奨する環境以外から本キャンペーンに応募したために情報を完全に取得できない場合。<br>\n6.故意または重過失なくして本キャンペーンが提供する情報が誤送信されるか、もしくは欠陥があった場合。</p>\n\n<p style=\"margin:15px 10px;font-size:15px;\">\n当社は、本キャンペーンの応募により応募者に生じた一切のトラブル・損害（直接・間接を問いません）について、如何なる責任も負いません。<br>\n本キャンペーンの応募にかかるインターネット接続料及び通信費は応募者のご負担となります。<br>\n本キャンペーンは、ミクチャを提供している当社（株式会社Donuts）が運営しているものであり、Apple社によって提供されているものではございません。</p>\n\n<div style=\"font-size:16px;padding:.75em 0;border-top:1px solid #B81649;border-bottom:1px solid #B81649;\">　▪️個人情報の取り扱いについて</div>\n\n<p style=\"margin:15px 10px;font-size:15px;\">\n住所、電話番号、氏名、性別、年齢、ミクチャアカウントURLの情報（以下「個人情報」といいます。）は、株式会社Donutsが管理します（管理責任者：ミクチャグループリーダー）。お客様の個人情報は、本キャンペーンの当選者への連絡・賞品の送付等の目的で利用し、それ以外の目的では使用致しません。また、お客様の個人情報をお客様の同意なしに業務委託先以外の第三者に開示・提供することはありません（法令等により開示を求められた場合を除きます。）。<br>\nまた、個人情報開示、訂正等のお問い合わせは、ミクチャ運営事務局（mixch-support@donuts.ne.jp）までお願い致します。</p>\n\n<div style=\"font-size:16px;padding:.75em 0;border-top:1px solid #B81649;border-bottom:1px solid #B81649;\">　▪️キャンペーンに関するお問い合わせ窓口</div>\n\n<p style=\"margin:15px 10px 20px;font-size:15px;\">[ミクチャスポンサー事務局]<br>\nmixch-support@donuts.ne.jp\n</p>\n\n<p></p></div><p></p>\n\n<p><img style=\"width:20%;margin:0 auto;padding:20px 0;display:block;\" src=\"https://d2uqarpmf42qy0.cloudfront.net/event/NIKU/mixch_LOGO.png\">\n</p></div>\n</div><p></p>\n\n<div id=\"tabView2\">\n<div class=\"box1\">\n\n<div class=\"box\">\n<h3 class=\"logo mzt\">特典</h3>\n\n<div style=\"margin:18px 10px 26px;padding:22px 14px;background:#111;border:2px solid #111;box-shadow:0 4px 0 #000;color:#fff;\">\n\n<div style=\"margin:0 auto 18px;padding:8px 12px;background:linear-gradient(90deg,#9E002D,#CE003B,#E54873);color:#fff;text-align:center;font-size:16px;font-weight:bold;letter-spacing:2px;\">\nEVENT❸\n</div>\n\n<p style=\"margin:0 0 18px;text-align:center;font-size:20px;font-weight:900;line-height:1.5;\">\nZOZOマリンスタジアムの<br>\n大型ビジョンで放映！\n</p>\n\n<p style=\"margin:0;text-align:center;font-size:15px;line-height:2;color:#ddd;\">\n8月25日開催「ミクチャDAY」当日、<br>\n試合中に放映されるミクチャCMに出演！<br><br>\n\nさらに、ポイントランキング上位者は<br>\n試合中常時掲出される<br>\n球場内ライトビジョンにも掲載✨<br><br>\n\nスタジアムで多くの観客の視線を集める、<br>\n特別な出演権を獲得できます⚾\n</p>\n\n<div style=\"margin:20px 0 4px;padding:14px 12px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.18);text-align:left;\">\n\n<p style=\"margin:0 0 10px;text-align:center;color:#E54873;font-size:16px;font-weight:bold;letter-spacing:1px;\">\nEVENT SCHEDULE\n</p>\n\n<p style=\"margin:0;font-size:15px;line-height:2;color:#fff;font-weight:bold;\">\n<span style=\"color:#E54873;\">募集｜</span><br>\n- 07/12(日) 24:00<br>\n\n<span style=\"color:#E54873;\">本選｜</span><br>\n07/03(金) 12:00 - 07/12(日) 24:00<br>\n\n<span style=\"color:#E54873;\">素材提出｜</span><br>\n07/20(月) 締切<br>\n\n<span style=\"color:#E54873;\">撮影(ポイントランキング1位2位のみ)｜</span><br>\n07/18(土) or7/24(金)いずれか1日\n\n\n</p>\n\n<p style=\"margin:8px 0 0;font-size:15px;line-height:1.7;color:#aaa;\">\n※CM制作に使用する素材は指定フォーマットにてご提出いただきます。\n</p>\n</div>\n<p style=\"margin:18px 10px 8px;font-size:15px;line-height:1.6;color:#aaa;text-align:center;\">\n＝昨年実施の様子＝\n</p>\n\n<center>\n<img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/66miyawaki/3T2A0449.JPG\" width=\"100%\">\n<br><br>\n\n<img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/66miyawaki/3T2A0129.JPG\" width=\"100%\">\n<br><br>\nCopyright © Chiba Lotte Marines All Rights Reserved.\n</center>\n\n</div>\n</div>\n\n<div class=\"box\">\n<h3 class=\"logo mzt\">受賞特典</h3>\n\n<div style=\"margin:18px 10px 26px;padding:22px 14px;background:#fff;border:2px solid #111;box-shadow:0 4px 0 #111;color:#111;\">\n\n<div style=\"margin:0 auto 18px;padding:8px 12px;background:#111;color:#fff;text-align:center;font-size:16px;font-weight:bold;letter-spacing:2px;\">\nPRIZE\n</div>\n\n<p style=\"margin:0 0 18px;text-align:center;font-size:18px;font-weight:900;line-height:1.7;\">\n試合中に放映される<br>\nミクチャCM出演権を獲得⚾✨\n</p>\n\n<p style=\"margin:0 0 24px;text-align:center;font-size:15px;line-height:1.9;color:#666;\">\n2回裏終了後・4回裏終了後に放映予定の<br>\nミクチャCMに出演！\n</p>\n\n<!-- 1位 -->\n\n<div style=\"padding:18px 0;border-bottom:1px solid #ddd;\">\n\n<p style=\"margin:0 0 8px;color:#CE003B;font-size:16px;font-weight:bold;\">\n🥇ポイントランキング1位\n</p>\n\n<p style=\"margin:0;font-size:20px;font-weight:900;line-height:1.7;\">\nCMメインモデルとして出演！\n</p>\n\n<p style=\"margin:10px 0 0;font-size:16px;line-height:1.9;\">\n動画出演＆セリフあり✨<br>\nミクチャCMのメインモデルとして掲載！\n</p>\n\n<p style=\"margin:14px 0 0;font-size:16px;font-weight:bold;line-height:1.8;color:#CE003B;\">\n＋ 試合中常時掲載✨️<br>\n球場内ライトビジョン メイン掲載\n</p>\n\n<p style=\"margin:6px 0 0;font-size:15px;line-height:1.8;color:#666;\">\n試合中常時掲出される注目のビジョンにモデル掲載！\n</p>\n\n</div>\n\n<!-- 2位 -->\n\n<div style=\"padding:18px 0;border-bottom:1px solid #ddd;\">\n\n<p style=\"margin:0 0 8px;color:#CE003B;font-size:16px;font-weight:bold;\">\n🥈ポイントランキング2位\n</p>\n\n<p style=\"margin:0;font-size:20px;font-weight:900;line-height:1.7;\">\nCMサブモデルとして出演！\n</p>\n\n<p style=\"margin:10px 0 0;font-size:16px;line-height:1.9;\">\n静止画で掲載予定✨\n</p>\n\n<p style=\"margin:14px 0 0;font-size:16px;font-weight:bold;line-height:1.8;color:#CE003B;\">\n＋ 試合中常時掲載✨️<br>\n球場内ライトビジョン サブ掲載\n</p>\n\n<p style=\"margin:6px 0 0;font-size:15px;line-height:1.8;color:#666;\">\n試合中常時掲出される注目のビジョンにモデル掲載！\n</p>\n\n</div>\n\n<!-- 3位 -->\n\n<div style=\"padding:18px 0;border-bottom:1px solid #ddd;\">\n\n<p style=\"margin:0 0 8px;color:#CE003B;font-size:16px;font-weight:bold;\">\n🥉ポイントランキング3位\n</p>\n\n<p style=\"margin:0;font-size:20px;font-weight:900;line-height:1.7;\">\nCMサブモデルとして出演！\n</p>\n\n<p style=\"margin:10px 0 0;font-size:16px;line-height:1.9;\">\n静止画で掲載予定✨\n</p>\n\n</div>\n\n<!-- CM合同掲載枠 -->\n\n<div style=\"padding:18px 0;\">\n\n<p style=\"margin:0 0 12px;text-align:center;font-size:16px;font-weight:bold;color:#CE003B;\">\n🎬 CM合同掲載枠\n</p>\n\n<p style=\"margin:8px 0 0;font-size:15px;line-height:1.8;text-align:center;\">\n4名合同掲載枠としてCM出演予定✨\n</p>\n\n<br>\n\n\n<div style=\"padding:14px;background:#fafafa;border:1px solid #ddd;margin-bottom:12px;\">\n\n<p style=\"margin:0 0 8px;color:#CE003B;font-size:16px;font-weight:bold;\">\n🎥 ムービーランキング1位\n</p>\n\n<p style=\"margin:0;font-size:17px;font-weight:900;line-height:1.7;\">\nCM内4名合同掲載枠に選出！\n</p>\n\n\n<p style=\"margin:8px 0 0;font-size:15px;color:#666;\">\n※ポイントランキング1位〜3位を除きます。\n</p>\n\n</div>\n\n<div style=\"padding:14px;background:#fafafa;border:1px solid #ddd;\">\n\n<p style=\"margin:0 0 8px;color:#CE003B;font-size:16px;font-weight:bold;\">\n🏅5万pt達成者のうち上位3名\n</p>\n\n<p style=\"margin:0;font-size:17px;font-weight:900;line-height:1.7;\">\nCM内4名合同掲載枠に選出！\n</p>\n\n<p style=\"margin:8px 0 0;font-size:15px;color:#666;\">\n※ポイントランキング1位〜3位、ムービーランキング1位を除きます。\n</p>\n\n</div>\n</div>\n</div>\n</div>\n\n<div class=\"box\">\n<h3 class=\"logo mzt\">達成条件</h3>\n\n<div style=\"margin:18px 10px 26px;padding:22px 14px;background:#fff;border:2px solid #111;box-shadow:0 4px 0 #111;color:#111;\">\n\n<div style=\"margin:0 auto 18px;padding:8px 12px;background:#111;color:#fff;text-align:center;font-size:16px;font-weight:bold;letter-spacing:2px;\">\nPOINT BONUS\n</div>\n\n<div style=\"padding:16px 0;border-bottom:1px solid #ddd;\">\n<p style=\"margin:0 0 6px;color:#CE003B;font-size:16px;font-weight:bold;\">\n50万pt達成で…\n</p>\n<p style=\"margin:0;font-size:16px;font-weight:bold;line-height:1.8;\">\n撮影稼働に伴う宿泊・交通費を<br>\n上限1万円まで支給\n</p>\n<p style=\"margin:8px 0 0;font-size:15px;line-height:1.8;\">\nさらに、撮影データを全プレゼント！\n</p>\n</div>\n\n<div style=\"padding:16px 0;border-bottom:1px solid #ddd;\">\n<p style=\"margin:0 0 6px;color:#CE003B;font-size:16px;font-weight:bold;\">\n75万pt達成で…\n</p>\n<p style=\"margin:0;font-size:16px;font-weight:bold;line-height:1.8;\">\n撮影稼働に伴う宿泊・交通費を<br>\n上限1.5万円まで支給\n</p>\n<p style=\"margin:8px 0 0;font-size:15px;line-height:1.8;\">\nさらに、撮影データに加えて<br>\nレタッチ済みデータも1枚プレゼント📸\n</p>\n</div>\n\n<div style=\"padding:16px 0;\">\n<p style=\"margin:0 0 6px;color:#CE003B;font-size:16px;font-weight:bold;\">\n100万pt達成で…\n</p>\n<p style=\"margin:0;font-size:16px;font-weight:bold;line-height:1.8;\">\n撮影稼働に伴う宿泊・交通費を<br>\n上限3万円まで支給\n</p>\n<p style=\"margin:8px 0 0;font-size:15px;line-height:1.8;\">\n75万pt達成特典の<br>\n撮影データ全プレゼント・レタッチ済みデータ1枚プレゼントも対象となります。\n</p>\n</div>\n\n<p style=\"margin:18px 0 0;font-size:15px;line-height:1.8;color:#666;\">\n※達成条件はポイントランキング1位、2位のみ対象です。<br>\n※交通費の支給は、ミクチャが指定する日での銀行振込となります。支給には、必ず公共交通機関の領収書が必要となりますのであらかじめご提出をお願い致します。(※グリーン車を除く)<br>\n</p>\n\n<p></p></div>\n</div><p></p>\n\n<div class=\"box\">\n<h3 class=\"logo mzt\">追加特典</h3>\n\n<div style=\"margin:18px 10px 26px;padding:22px 14px;background:#111;border:2px solid #111;box-shadow:0 4px 0 #000;color:#fff;\">\n\n<div style=\"margin:0 auto 18px;padding:8px 12px;background:linear-gradient(90deg,#9E002D,#CE003B,#E54873);color:#fff;text-align:center;font-size:16px;font-weight:bold;letter-spacing:2px;\">\nSPECIAL PRIZE\n</div>\n\n<p style=\"margin:0;text-align:center;font-size:16px;font-weight:bold;color:#FFD700;letter-spacing:1px;\">\n🎉 スペシャル特典追加決定!! 🎉\n</p>\n\n<p style=\"margin:16px 0 0;text-align:center;font-size:20px;font-weight:900;line-height:1.6;\">\n10万pt達成者全員\n</p>\n\n<p style=\"margin:12px 0 0;text-align:center;font-size:18px;font-weight:900;line-height:1.8;color:#fff;\">\n千葉ロッテマリーンズ<br>\n「ミクチャDAY」<br>\nファーストピッチ投球者決定戦\n</p>\n\n<p style=\"margin:8px 0 0;text-align:center;font-size:22px;font-weight:900;line-height:1.6;color:#FFD700;text-shadow:0 0 8px rgba(255,215,0,.45);\">\n🔥 最終決戦への<br>\nシード権獲得!!\n</p>\n\n<p></p><hr style=\"border:none;border-top:1px solid rgba(255,255,255,.15);margin:20px 0;\"><p></p>\n\n<p style=\"margin:0;text-align:center;font-size:16px;line-height:2;color:#ddd;\">\n8月25日開催<br>\n千葉ロッテマリーンズ「ミクチャDAY」当日、<br>\nスタジアムで大きな注目を集める\n<b>ファーストピッチ投球権</b>をかけた<br>\n<b>最終決戦イベント</b>へ進出できます⚾✨\n</p>\n\n<div style=\"margin:18px 0 0;padding:14px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.18);\">\n\n<p style=\"margin:0 0 8px;color:#E54873;font-size:16px;font-weight:bold;text-align:center;\">\nEVENT SCHEDULE\n</p>\n\n<p style=\"margin:0;text-align:center;font-size:16px;font-weight:bold;line-height:1.9;\">\n8月3日(月)18:00<br>\n～<br>\n8月9日(日)24:00\n</p>\n\n</div>\n\n<p style=\"margin:18px 0 0;font-size:15px;line-height:1.9;text-align:center;color:#aaa;\">\n※10万pt達成者全員が対象となります。<br>\n※詳細は後日結果ページにてご案内いたします。\n</p>\n\n<p></p></div>\n</div><p></p>\n\n<div class=\"box\">\n<h3 class=\"logo mzt\">参加条件</h3>\n\n<div style=\"margin:18px 10px 26px;padding:22px 14px;background:#fff;border:2px solid #111;box-shadow:0 4px 0 #111;color:#111;\">\n\n<div style=\"margin:0 auto 18px;padding:8px 12px;background:#111;color:#fff;text-align:center;font-size:16px;font-weight:bold;letter-spacing:2px;\">\nENTRY REQUIREMENTS\n</div>\n\n<p style=\"margin:0;font-size:15px;line-height:1.9;\">\n本イベントは、下記の条件を満たしている方がエントリー可能です。<br>\n<span style=\"color:#CE003B;font-weight:bold;\">●</span> 素材提出およびご自身の音声込みでの掲載が可能な方<br>\n<span style=\"color:#CE003B;font-weight:bold;\">●</span> ソロアカウントの方<br>\n<span style=\"color:#CE003B;font-weight:bold;\">●</span> 指定フォーマットに沿った素材提出が可能な方<br>\n<span style=\"color:#CE003B;font-weight:bold;\">●</span> 事務所所属者は、事前に所属事務所の許諾を得ている方<br>\n<span style=\"color:#CE003B;font-weight:bold;\">●</span> 未成年者は、事前に保護者の同意を得ている方\n</p>\n\n<p></p></div>\n</div><p></p>\n\n<div class=\"box\">\n<h3 class=\"logo mzt\">注意事項</h3>\n\n<div style=\"margin:18px 10px 26px;padding:22px 14px;background:#fff;border:2px solid #111;box-shadow:0 4px 0 #111;color:#111;\">\n\n<div style=\"margin:0 auto 18px;padding:8px 12px;background:#111;color:#fff;text-align:center;font-size:16px;font-weight:bold;letter-spacing:2px;\">\nNOTE\n</div>\n\n<p style=\"margin:0 0 10px;color:#CE003B;font-size:15px;font-weight:bold;\">\n【CM放映について】\n</p>\n\n<p style=\"margin:0;font-size:15px;line-height:1.9;\">\nCMは、8月25日(火)開催「ミクチャDAY」当日の試合中に放映予定です。<br>\n放映タイミングは、2回裏終了後・4回裏終了後の合計2回を予定しております。<br>\nCMのメイン掲載・サブ掲載は、掲出秒数や掲載人数等の内容が異なります。\n<br><br>\n\n天候・試合進行・球団都合等により、放映タイミングや内容が変更となる場合がございます。<br>\nまた、CMは当日の試合観戦チケットをお持ちの方のみご覧いただけます。<br>\n\n\n</p>\n\n<hr style=\"border:none;border-top:1px solid #ddd;margin:16px 0;\">\n\n<p style=\"margin:0 0 10px;color:#CE003B;font-size:15px;font-weight:bold;\">\n【撮影について】\n</p>\n\n<p style=\"margin:0;font-size:15px;line-height:1.9;\">\nライトビジョン掲載用のクリエイティブは撮影データをもとに制作いたします。<br>\n<b><u>7月18日(土)もしくは7月24日(金)</u></b>に都内スタジオにて撮影を予定しておりますので、終日スケジュールの確保をお願いいたします。<br><br>\n\n撮影日程への参加が難しい場合は、お住まい地域のスタジオにて撮影したデータ（レタッチ済）のご提出も可能です。<br>\n※スマートフォン撮影データは不可となります。<br><br>\n\nその場合、提出期限を<b>【7月27日(月)〆】</b>とさせていただきます。<br>\nまた、達成特典にて交通費・宿泊費支給対象となっている場合は、その同額を上限としてスタジオ代を後日支給いたします。<br>\n※領収書の提出が必要です。\n<br><br>\n\nデータ提出をご希望の場合は、結果発表後に必ずご申告ください。<br>\nご申告がない場合は、指定撮影日にご参加いただけるものとして進行いたします。<br><br>\n\n指定フォーマットに沿ったデータでない場合は、再提出をお願いする場合や、掲載をお断りする場合がございます。<br>\nまた、撮影方法・ポージング等を指定させていただく場合がございます。\n</p>\n\n<hr style=\"border:none;border-top:1px solid #ddd;margin:16px 0;\">\n\n<p style=\"margin:0 0 10px;color:#CE003B;font-size:15px;font-weight:bold;\">\n【素材提出について】\n</p>\n\n<p style=\"margin:0;font-size:15px;line-height:1.9;\">\nCMは、提出いただいた素材をもとに制作いたします。<br>\n素材提出期限は<b>【7月20日(月)中】</b>となります。<br>\n※ポイントランキング1位、2位特典のライトビジョンに関しては、撮影したデータにてクリエイティブを制作致します。<br>\n<br>\n提出素材は、必ず指定フォーマットに沿ってご提出ください。<br>\n指定フォーマットに沿ったデータでない場合は、再提出をお願いする場合や、掲載をお断りする場合がございます。<br>\n※期限までに素材提出が確認できない場合、掲載できない可能性がございます。\n</p>\n\n<p style=\"margin-top:8px;font-size:15px;line-height:1.8;color:#666;\">\n■ 以下に該当する素材はご提出いただけません。<br>\n・極端に近すぎるもの（顔が切れている等）<br>\n・写真データの解像度が条件を満たしていないもの<br>\n・画像内に文字が入っているもの<br>\n・過度な加工がされているもの<br>\n・千葉ロッテマリーンズ以外の球団商標が入っているもの<br>\n・キャラクターやロゴ等、第三者の著作権を侵害しているもの<br>\n・公序良俗に反するものや広告掲載に相応しくないもの\n</p>\n\n<p></p></div>\n</div><p></p>\n\n<p><img style=\"width:20%;margin:0 auto;padding:20px 0;display:block;\" src=\"https://d2uqarpmf42qy0.cloudfront.net/event/NIKU/mixch_LOGO.png\"></p>\n\n<p></p></div>\n</div><p></p>\n\n<style type=\"text/css\">.tab-content input[type=\"radio\"] { display: none; }\ndiv.content { color: rgb(0, 0, 0); line-height: 1.75; font-family: YuGothic; font-size: 15px; }\n.tab-content label { display: inline-block; padding: 5px; font-weight: bold; font-size: 15px; color: rgb(255, 255, 255); background-color: rgb(220, 220, 220); cursor: pointer; border-radius: 3px 3px 0px 0px; box-sizing: border-box; border-width: 2px 2px medium; border-style: solid solid none; border-color: rgb(220, 220, 220) rgb(220, 220, 220) currentcolor; border-image: initial; }\n.tab-content label:hover { opacity: 0.3; }\n.tab-content input[type=\"radio\"]:checked + label { color: rgb(255, 255, 255); background-color: rgb(0, 0, 0); border-width: 2px 2px medium; border-style: solid solid none; border-color: rgb(184, 22, 74) rgb(184, 22, 74) currentcolor; border-image: initial; }\n.tab-content .tab-box { width: 100%; height: auto; border-radius: 0px 5px 5px; box-sizing: border-box; }\n.tab-content > .tab-box > div { display: none; }\n#tab1:checked ~ .tab-box > #tabView1, #tab2:checked ~ .tab-box > #tabView2, #tab3:checked ~ .tab-box > #tabView3, #tab4:checked ~ .tab-box > #tabView4 { display: block; }\n#tabView1, #tabView2, #tabView3, #tabView4, #tabView5 { background: repeating-linear-gradient(90deg, rgb(247, 247, 247) 0px, rgb(247, 247, 247) 18px, rgb(236, 236, 236) 18px, rgb(236, 236, 236) 20px); }\n.tab-box h3.logo { margin: 0px 15px 10px; padding: 15px 5px 10px; background-image: linear-gradient(120deg, rgb(184, 22, 73) 0%, rgb(238, 157, 164) 100%); background-repeat: no-repeat; background-size: 60% 2px; background-position: 0px 100%; line-height: 2em; }\n.tab-box h3.logo::before { background: url(\"https://d2uqarpmf42qy0.cloudfront.net/event/25_hatamura/img/common/mixcha-logo-black-outline-512x512px.png\") center center / contain no-repeat; display: inline-block; margin: 0px 10px 0px 0px; content: \"\"; width: 2em; height: 2em; vertical-align: bottom; filter: invert(77%) sepia(94%) saturate(1346%) hue-rotate(293deg) brightness(100%) contrast(86%); }\ndiv.content ul { padding: 0px 2em 0px 3em; }\ndiv.content table { padding: 5px 2em; }\ndiv.content table tr { line-height: 1.5; }\ndiv.content table tr { vertical-align: bottom; }\ndiv.content table th { font-weight: bold; text-align: left; }\ndiv.button-container { margin: 20px 20px 30px; font-size: 16px; font-weight: bold; text-align: center; }\ndiv.button-container img { display: inline-block; }\n.precaution { line-height: 1.25; color: rgb(96, 96, 96); margin-bottom: 20px; }\ndiv.content div.judges, div.content div.yad-members { padding: 0px 40px; }\ndiv.content div.judges h4 { font-size: 16px; font-weight: bold; border-bottom: 1px solid rgb(128, 128, 128); margin: 40px 20px 10px; }\ndiv.content div.yad-members h4 { font-size: 16px; font-weight: bold; margin: 40px 20px 10px; }\ndiv.content div.judges .portrait, div.content div.yad-members .portrait { text-align: center; }\ndiv.content div.judges .portrait img, div.content div.yad-members .portrait img { width: 160px; display: inline-block; margin: 5px 0px; }\ndiv.content img.footer-logo { width: 20%; margin: 0px auto; padding: 40px 0px; display: block; }\ndiv.content div.yad-members h5 { font-size: 15px; font-weight: bold; margin: 5px 20px 0px; }\ndiv.content a.link-btn, div.content a.link-btn:link, div.content a.link-btn:visited { margin: 5px 0px; display: inline-block; padding: 5px 10px; border: 2px solid rgb(184, 22, 73); border-radius: 70px; transition: 0.125s; text-decoration: none; font-size: 15px; font-weight: bold; line-height: 1.5; color: rgb(184, 22, 73); }\ndiv.content a.link-btn > span, div.content a.link-btn:link > span, div.content a.link-btn:visited > span { color: rgb(184, 22, 73); transition: 0.125s; font-size: 16px; }\ndiv.content a.link-btn:hover { background-color: rgb(184, 22, 73); color: rgb(255, 255, 255); }\ndiv.content a.link-btn:hover > span { color: rgb(255, 255, 255); }\ndiv.content a.link-btn:active { background-color: rgb(184, 22, 73); box-shadow: rgba(0, 0, 0, 0) 0px 0px 0px; transition: all; }\n.box { padding: 3px 0px; background: rgba(255, 255, 255, 0.82); border: 2px solid rgb(17, 17, 17); margin: 10px 5px 30px; border-radius: 4px; backdrop-filter: blur(2px); }\n.box1 { padding: 10px; }\n.inline-block_test { display: inline-block; padding: 5px; height: 90px; border: 3px solid rgb(135, 206, 235); }\n.point { color: rgb(184, 22, 73); font-weight: bold; font-size: 14px; }\n.gradbox { color: rgb(255, 255, 255); width: 70%; border-radius: 30px; height: auto; background-image: linear-gradient(97deg, rgb(184, 22, 73) 0%, rgb(232, 114, 124) 50%, rgb(184, 22, 73) 100%); font-weight: bold; }\n.gradboxinner { padding: 1%; border-radius: 30px; }\n.ranking { height: 95px; text-align: center; background-image: url(\"https://d2uqarpmf42qy0.cloudfront.net/event/23uchiyama/月柱冠.png\"); background-size: contain; background-position: center center; background-repeat: no-repeat; position: relative; }\n.ranking_item { position: absolute; top: 50%; left: 50%; transform: translateY(-50%) translateX(-50%); padding: 20px; font-size: 15px; font-weight: bold; }\n.typewriter { display: inline-block; white-space: nowrap; overflow: hidden; border-right: 2px solid rgb(255, 255, 255); }\n.line1 { width: 0px; animation: 1.5s steps(30) 0s 1 normal forwards running typing1, 0.75s step-end 0s infinite normal none running blink; }\n.line2 { width: 0px; animation: 1.5s steps(30) 1.6s 1 normal forwards running typing2, 0.75s step-end 1.6s infinite normal none running blink; }\n.line3 { width: 0px; animation: 1.5s steps(30) 3.2s 1 normal forwards running typing3, 0.75s step-end 3.2s infinite normal none running blink; }\n@keyframes typing1 { \n  0% { width: 0px; }\n  100% { width: 100%; }\n}\n@keyframes typing2 { \n  0% { width: 0px; }\n  100% { width: 100%; }\n}\n@keyframes typing3 { \n  0% { width: 0px; }\n  100% { width: 100%; }\n}\n@keyframes blink { \n  50% { border-color: transparent; }\n}\n</style>\n\n<!-- CSSセクションおわり💡 -->\n\n<p></p></div>\n</div>\n</div><p></p>\n</div>"
}