  "detailHtml": "<div class=\"content\"><style>*{max-width:100% !important;}*::before{max-width:100% !important;}*::after{max-width:100% !important;};  .cf:after{content:&apos; &apos;;display:block;clear:both;height:0;}.cf{display:inline-block;}.cf{display:block;}body{background:#f8f7f4;font-family:Hiragino Kaku Gothic Pro,Meiryo,MS PGothic,sans-serif;font-size:16px;line-height:1.4;letter-spacing:0.05em;margin:0px;color:#3c3c3c;overflow-y:hidden;overflow-x:hidden;padding:0px 5px;}img{vertical-align:bottom;border:none;outline:none;}a,.text-link{text-decoration:none;outline:none;color:#ef9500;cursor:pointer;}a:hover,.text-link:hover{text-decoration:underline;}input,select,option,textarea{font-family:Hiragino Kaku Gothic Pro,Meiryo,MS PGothic,sans-serif;}.center{text-align:center;}.right{text-align:right;}.button-green{color:#fff;display:block;width:100%;box-sizing:border-box;padding:10px 0 9px 0;margin:0 auto;cursor:pointer;font-size:15px;font-weight:bold;text-align:center;border-radius:3px;-moz-border-radius:3px;-webkit-border-radius:3px;background-color:#65b721;background-image:-webkit-gradient(\n      linear,left top,left bottom,from(#6ac023),to(#65b721)\n    );background-image:-webkit-linear-gradient(top,#6ac023,#65b721);background-image:-moz-linear-gradient(top,#6ac023,#65b721);background-image:-o-linear-gradient(top,#6ac023,#65b721);background-image:linear-gradient(top,#6ac023,#65b721);border:solid 1px #61bc14;text-shadow:0 1px 1px #135e00;box-shadow:0 3px 0 #467f17;}.button-green:hover{text-decoration:none;background:#84d933;}.button-green-s{color:#fff;box-sizing:border-box;cursor:pointer;font-weight:bold;text-align:center;border-radius:3px;-moz-border-radius:3px;-webkit-border-radius:3px;background-color:#65b721;background-image:-webkit-gradient(\n      linear,left top,left bottom,from(#6ac023),to(#65b721)\n    );background-image:-webkit-linear-gradient(top,#6ac023,#65b721);background-image:-moz-linear-gradient(top,#6ac023,#65b721);background-image:-o-linear-gradient(top,#6ac023,#65b721);background-image:linear-gradient(top,#6ac023,#65b721);text-shadow:0 1px 1px #135e00;display:inline-block;font-size:16px;padding:8px 11px 7px 11px;margin:0;width:auto;border:solid 1px #61bc14;box-shadow:0 3px 0 #467f17;}.button-green-s:hover{text-decoration:none;background:#84d933;}.content{background:#fff;margin:0 0 20px 0;padding:0 0 1px 0;box-shadow:0 1px 1px #ccc;}.content p{padding:0 10px;margin:0 0 10px 0;}.content h1{display:none;}.content h2{font-size:16px;background:#f5f5f5;border-left:solid 8px #cece2b;padding:8px 0 8px 8px;}.content h3{padding:0 0 0 5px;margin:0;}.menu{background-color:#333;padding:5px 30px;color:white;width:100%;}</style><p>\n<style>h1 { display: none; }\n</style>\n</p><div class=\"main-content\" style=\"max-width:480px;margin:0 auto;\">\n<br><p></p>\n\n<!-- 💡タブセクションはじめ -->\n\n<div class=\"tab-content\">\n<input type=\"radio\" id=\"tab1\" name=\"tab\" checked=\"\">\n<label for=\"tab1\">概要</label>\n<input type=\"radio\" id=\"tab2\" name=\"tab\">\n<label for=\"tab2\">二次審査（ミクチャ/面接）</label>\n<!--\n<input type=\"radio\" id=\"tab3\" name=\"tab\">\n<label for=\"tab3\"> ファン増加/配信時間ランキング</label>\n<input type=\"radio\" id=\"tab4\" name=\"tab\">\n<label for=\"tab4\"> ゲリラ</label>\n-->\n\n\n<!-- タブセクションおわり💡 -->\n\n<!-- 💡1タブの中身はじめ -->\n<link href=\"https://cdnjs.cloudflare.com/ajax/libs/lightbox2/2.7.1/css/lightbox.css\" rel=\"stylesheet\">\n<script src=\"https://ajax.googleapis.com/ajax/libs/jquery/3.1.1/jquery.min.js\"></script>\n<script src=\"https://cdnjs.cloudflare.com/ajax/libs/lightbox2/2.7.1/js/lightbox.min.js\" type=\"text/javascript\"></script>\n\n<div class=\"tab-box\">\n<div id=\"tabView1\" class=\"tabView\">\n<div style=\"background-color:rgba(255,255,255,0.5);color:#735d65;font-size:15px;\">\n<h3 class=\"logo\">イベント概要</h3>\n<center><img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/mainvisual.png\" width=\"70%\"><br>\n</center>\n\n<br>\n<center>\n<p style=\"margin:10px;font-size:15px;\">\n<b>きゅ〜くる新メンバー＆金澤有希プロデュース新グループ<br>\n合同オーディション開催！</b>\n</p></center>\n<br>\n\n\n<center>\n<b>\n<a class=\"link-btn\" href=\"https://arcjewel.com/cuclu/\" target=\"_blank\" referrerpolicy=\"no-referrer\">公　式　H　P</a>\n</b>\n</center>\n\n<br>\n\n<h3 class=\"logo\">総合プロデューサー金澤有希より</h3>\n<br>\n<center><img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41yaguchi/第1希望.jpg\" width=\"80%\"></center>\n<br>\n<p style=\"margin:10px;font-size:15px;\">\nきゅ〜くるプロデューサーの金澤有希です。<br>\n<br>\nこの度、きゅ〜くるの新メンバー、そして私がプロデュースする新グループのメンバーを募集いたします！<br>\n<br>\n経験の有無は問いません。<br>\n大切なのは「アイドルになりたい」という強い気持ちと、夢に向かって努力できることです！<br>\n<br>\nまだ自分に自信がなくても大丈夫。<br>\nあなたにしかない魅力を、一緒に見つけていけたらいいなと思っています！<br>\n<br>\n私がプロデュースするグループは、ただアイドルになるためだけの場所ではありません。個性を大切にしながら、夢や目標に本気で向き合える場所を目指しています。<br>\n<br>\n楽しく、そして真剣に。<br>\n一緒に夢を叶えていきましょう！<br>\n<br>\nあなたのご応募をお待ちしています！<br>\n<br>\n金澤有希より<br>\n\n<br>\n\n\n\n</p><h3 class=\"logo\">スケジュール</h3>\n<p style=\"margin:10px;font-size:15px;\">\n<b>■二次審査</b><br>\n　<b>前半（ミクチャ）</b><br>\n　07/08(水) 20:00 〜 07/20(月) 22:00<br>\n<br>\n　<b>中間（面接）</b><br>\n　07/21(火）〜 07/26 (日 ) のいずれか<br>\n<br>\n　<b>後半（ミクチャ）</b><br>\n　07/27(月) 18:00 〜 08/09(日) 22:00<br>\n<br>\n<b>■二次審査 結果発表</b><br>\n　08/10(月) 予定 <br>\n<br>\n<b>■最終審査</b><br>\n　08/14(金) 〜 08/16(日)のいずれか予定 <br>\n <br>\n<b>■合格発表・活動開始</b><br>\n　<b>きゅ〜くる新メンバーお披露目</b><br>\n　08/23(日) 東京キネマ倶楽部<br>\n<br>\n　<b>新グループデビュー</b><br>\n　11月〜12月頃を予定 <br>\n</p>\n<br>\n<h3 class=\"logo\">注意事項</h3>\n<p style=\"margin:10px;font-size:15px;\">\n■LIVE配信＋ムービー投稿によって獲得したポイントの合算がアプリ内ランキングに表示されます。<br>\n■<b>今回のオーディションは配信者へのキャッシュバックはございません。</b><br>\n■今回のオーディション応募において審査参加費は掛かりません。但し、審査過程で発生する交通費及び宿泊費、食費、通信費等はすべてご自身での負担となります。<br>\n■当オーディションにて得た情報やその他進行状況などは、主催の許可がない限りSNSへの投稿含む第三者への口外は一切禁じます。<br>\n■選考結果及び書類通過後の日程は通過者にのみご連絡いたします。<br>\n■個別の審査結果や審査状況等のお問い合わせにはお答えできません。予めご了承ください。<br>\n■上記日程は選考状況により変更となる可能性もございます。変更になった場合は通過者の皆様へご案内いたします。予めご了承ください。<br>\n\n<br>\n</p>\n\n\n<a href=\"https://mixch.tv/p/qjtg97sp\" target=\"_blank\" referrerpolicy=\"no-referrer\"><center><img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/koizumi/1811_kokoroe.png\" width=\"70%\"></center></a>\n<br>\n\n<div style=\"margin:10px;border:#FE0083 solid 1px;display:block;padding:.2em .3em;\">\n<h3 style=\"border-left:#FE0083 solid 6px;padding:.3em.3em.3em.8em;\">審査について</h3>\n</div>\n<p style=\"margin:10px;font-size:15px;\">\n●ライブ配信・動画投稿をする際は必ず<b><font color=\"#FE0083\">[ きゅ〜くる新メンバー＆金澤有希プロデュース新グループメンバー合同オーディション ]のイベント選択</font></b>をお願いします。正しく選択をしていない場合は獲得したミクチャポイントがランキングに反映されませんのでご注意ください。また、誤ってイベント選択した際にポイントを対象イベントに反映することはできかねますので予めご了承ください。<br>\n<br>\n●当該ページの審査項目に沿って受賞者が決定いたします。なお、審査の過程や受賞者の決定に至った理由等につきましてはお答え出来ませんのであらかじめご了承ください。<br>\n<br>\n●獲得したポイントが同一の場合は、下記の条件に従って順位を決定します。((1)から条件を適用し、順位が決定しない場合はその次の条件を適用して決定し、以下同様の処理をします。)<br>\n<br>\n<font size=\"3\">\n　(1) 対象となるイベントを選択してライブ配信をした「配信時間」の合計が多いユーザーを上位とします。<br>\n　(2) 対象となるイベントを選択してライブ配信をした「配信回数」の合計が多いユーザーを上位とします。<br>\n　(3) 対象となるイベントを選択して行ったライブ配信・投稿動画に対して受け取った「コメント数」の合計が多いユーザーを上位とします。<br>\n　(4) 対象となるイベントへの応募申し込みが早かったユーザーを上位とします。<br>\n　(5) もし(1)～(5)全てが同じ場合はミクチャの「ユーザーIDの数字が小さい」ユーザーを上位とします。<br>\n</font>\n<br><br>\n※下記の注意事項も必ずお読みください。</p>\n\n<div style=\"margin:10px;border:#FE0083 solid 1px;display:block;padding:.2em .3em;\">\n<h3 style=\"border-left:#FE0083 solid 6px;padding:.3em.3em.3em.8em;\">アイテム送信に関する注意点</h3>\n</div>\n<p style=\"margin:10px;font-size:15px;\">\n●ライブ配信で、イベント終了間際など同時間帯に大量のアイテムを投げると、多数のアイテムリクエストによりコイン消費に遅延が生じる可能性がございます。ムービーでは遅延が生じることはないので、ムービーイベントの場合は投稿動画への積極的な送信をご検討ください。<br>\n●ライブ配信の場合、イベント期間中にライバーの端末側でアイテムのアニメーション再生が始まったアイテムはイベントのポイントに加算されます。イベント期間中に再生失敗したアイテムやイベント期間をすぎてから再生されたアイテムは、イベントのポイントに加算されません。<br>\n●なお、上記の事象が発生した場合においても、イベントへのポイント反映やコインの返却などのご対応は出来かねますのでご了承くださいませ。<br>\nそのため、ライブ配信ではできるだけ一気に大量に送るのではなく、定期的にアイテムを送るかムービーへのアイテム送信を推奨いたします。<br>\n</p>\n\n<div style=\"margin:10px;border:#FE0083 solid 1px;display:block;padding:.2em .3em;\">\n<h3 style=\"border-left:#FE0083 solid 6px;padding:.3em.3em.3em.8em;\">応募規約</h3>\n</div>\n<p style=\"margin:10px;font-size:15px;\">\n本キャンペーンに応募いただける方（以下、「応募者」といいます。）は、以下をよくお読みいただき、同意の上ご応募ください。<br><br>\nミクチャにて、「イベントに参加する」をタップした時点で本規約に同意したものとみなします。万が一ご同意いただけない場合は応募を中止してください。<br>\n本規約の内容は、事前の告知なく変更される場合がありますので、予めご了承ください。<br>\n</p>\n<div style=\"font-size:16px;padding:.75em 0;border-top:1px solid #FE0083;border-bottom:1px solid #FE0083;\">\n　▪️動画投稿・ライブ配信での注意事項\n</div>\n<p style=\"margin:10px;font-size:15px;\">\n●撮影・ライブ配信が禁止されている場所または危険な場所での撮影やライブ配信はお控え下さい。<br>\n●楽曲を使用する場合は著作権者から楽曲利用の許可がおりているものをお使いください。<br>\n●大声を出す・大音量で音楽を流す、道を塞ぐなど、人の迷惑になる行為は控えて、撮影やライブ配信を実施してください。<br>\n</p>\n<p style=\"margin:10px;font-size:15px;\">\n●応募者と一緒に投稿動画・ライブ配信に写っている方がいらっしゃる場合や、第三者の知的財産権が含まれる場合、必ず投稿やライブ配信前に権利者から使用許諾を得てください。<br>\nまた、応募者は投稿動画・ライブ配信について自らが投稿・ライブ配信することについての適法な権利を有していること及び第三者の一切の権利を侵害していないことについて当社に対し表明し、保証するものとします。万が一、第三者からの権利侵害等の申し立てがあった場合には、投稿者や配信者ご自身の責任をもって解決していただきますので、予めご了承ください。<br>\n●ミクチャ以外のプラットフォームで作成した動画をミクチャでアップロードする場合、当該プラットフォームの利用規約に沿って投稿してください。<br>\n●未成年の方は保護者の同意を得た上でご応募ください。また、必要に応じて、在籍する学校または所属する部活動が加盟する連盟等へ確認をとったうえで応募してください。<br>\n●事務所、劇団、その他の団体（以下「事務所等」といいます）に所属されている方は、ご自身の責任で事務所等に本キャンペーンへの応募の可否につきご確認ください。<br>\n●コンテストなどの新しい才能の発掘を目的としたものや、事務所所属者や新グループメンバーの選定を目的とした一般的な「オーディション」に関するイベントには、キャッシュバックのお支払いはございません。なお、一部対象外のものもございますので、ご不明な場合はお問い合わせください。<br>\n●上記各項への違反や極端に他人に不快感を与えるような言動や、法律に抵触する内容、ミクチャの利用規約に違反した内容、運営事務局が不適切と判断した動画やライブ配信については削除、もしくはキャッシュバックや審査、受賞の対象外とする可能性がございますのでご了承ください。<br>\n●本応募規約に定める事項のほか、ミクチャ利用規約及びプライバシーポリシーが適用されますので、確認の上、ご応募ください。<br>\n</p>\n\n<div style=\"font-size:16px;padding:.75em 0;border-top:1px solid #FE0083;border-bottom:1px solid #FE0083;\">\n　▪️賞品・受賞について\n</div>\n<p style=\"margin:10px;font-size:15px;\">\n●受賞者と連絡がつかない場合、賞品受領の意思が確認できない場合、指定された期日までに連絡先をご返信いただけない場合等には、受賞を辞退されたものとみなし、受賞を無効とさせていただきます。予めご了承ください。<br>\n●受賞の権利は受賞者ご本人のものであって、第三者へ譲渡・換金等することはできません。また、受領した賞品の紛失等による再送付、受賞者の事情による変更、その他クレーム等には一切応じることができません。<br>\n●当社は、賞品の品質及び、目的適合性について何ら保証することはできかねます。賞品の使用に当たっては、賞品に記載の注意事項をご確認の上、ご使用ください。受賞された賞品の使用中に生じた事故等のトラブルについての責任は、当社では負いかねます。<br>\n●賞品提供元の何らかの事由により特典不履行となる事案が生じた場合は、代替賞品による補填などで対応することがございますのでご了承くださいませ。<br>\n</p>\n\n<div style=\"font-size:16px;padding:.75em 0;border-top:1px solid #FE0083;border-bottom:1px solid #FE0083;\">\n　▪️禁止事項\n</div>\n<p style=\"margin:10px;font-size:15px;\">\n本キャンペーンへの応募に際し、以下の行為を禁止します。当社は、応募者が以下に該当する行為を行ったと判断した場合は、応募者への事前通告なく、対象投稿を掲載しない、掲載後削除する、応募・受賞を無効とするなどの対応をとる場合があります。<br>\n<br>\n・本規約または法令に違反する行為<br>\n・本キャンペーンの運営を妨げる行為<br>\n・他人に迷惑、不利益、損害または不快感を与える行為<br>\n・他人を誹謗中傷し、またはその名誉若しくは信用を毀損する行為<br>\n・第三者の著作権その他の知的財産権を侵害する行為<br>\n・他人の財産、プライバシー若しくは肖像権を侵害する行為<br>\n・わいせつ、児童ポルノ及び児童の性的搾取を助長するデータを投稿する行為<br>\n・営利を目的とした情報提供、広告宣伝もしくは勧誘行為<br>\n・公序良俗に反する行為<br>\n・ミクチャの利用規約に違反する行為<br>\n・その他、前各号に類する行為<br>\n</p>\n\n<div style=\"font-size:16px;padding:.75em 0;border-top:1px solid #FE0083;border-bottom:1px solid #FE0083;\">\n　▪️免責・その他\n</div>\n<p style=\"margin:10px;font-size:15px;\">\n本キャンペーンは、細心の注意を払って運営をしていますが、提供する情報、プログラム、各種サービス、その他本キャンペーンに関するすべての事項について、その完全性、正確性、安全性、有用性等について、いかなる保証もするものではありません。また、利用者または第三者が被った以下の事例を含む損害については、当社は責任を負いかねます。<br>\n<br>\n1.本キャンペーンへの応募に際して、ソフトウェア・ハードウェア上の事故、火災、停電、通信環境の悪化、地震、事変等の非常事態が発生した場合。<br>\n2.本キャンペーンにおけるシステムの保守を定期的あるいは緊急に行う場合。<br>\n3.利用者間または利用者と第三者の間におけるトラブル等が生じた場合。<br>\n4.第三者による本キャンペーンのサービスの妨害、情報改変などによりサービスが中断もしくは遅延し、何らかの欠陥が生じた場合。<br>\n5.当社が推奨する環境以外から本キャンペーンに応募したために情報を完全に取得できない場合。<br>\n6.故意または重過失なくして本キャンペーンが提供する情報が誤送信されるか、もしくは欠陥があった場合。<br>\n<br>\n当社は、本キャンペーンの応募により応募者に生じた一切のトラブル・損害（直接・間接を問いません）について、如何なる責任も負いません。<br>\n本キャンペーンの応募にかかるインターネット接続料及び通信費は応募者のご負担となります。<br>\n本キャンペーンは、ミクチャを提供している当社（株式会社Donuts）が運営しているものであり、Apple社によって提供されているものではございません。<br>\n</p>\n\n<div style=\"font-size:16px;padding:.75em 0;border-top:1px solid #FE0083;border-bottom:1px solid #FE0083;\">\n　▪️個人情報の取り扱いについて\n</div>\n<p style=\"margin:10px;font-size:15px;\">\n住所、電話番号、氏名、性別、年齢、ミクチャアカウントURLの情報（以下「個人情報」といいます。）は、株式会社Donutsが管理します（管理責任者：ミクチャグループリーダー）。お客様の個人情報は、本キャンペーンの当選者への連絡・賞品の送付等の目的で利用し、それ以外の目的では使用致しません。また、お客様の個人情報をお客様の同意なしに業務委託先以外の第三者に開示・提供することはありません（法令等により開示を求められた場合を除きます。）。<br>\nまた、個人情報開示、訂正等のお問い合わせは、ミクチャ運営事務局（mixch-support@donuts.ne.jp）までお願い致します。<br>\n</p>\n\n<div style=\"font-size:16px;padding:.75em 0;border-top:1px solid #FE0083;border-bottom:1px solid #FE0083;\">\n　▪️キャンペーンに関するお問い合わせ窓口\n</div>\n<p style=\"margin:10px;font-size:15px;\">\n[ミクチャスポンサー事務局]<br>\nmixch-support@donuts.ne.jp<br>\n</p>\n\n<center><img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/NIKU/mixch_LOGO.png\" width=\"20%\"></center>\n<br><br>\n</div>\n</div>\n\n<!-- 1タブの中身おわり💡 -->\n\n<!-- 💡2タブの中身はじめ -->\n\n<div id=\"tabView2\" class=\"tabView\">\n<div style=\"background-color:rgba(255,255,255,0.5);color:#735d65;font-size:15px;\">\n\n<h3 class=\"logo\">二次審査 概要</h3>\n<p style=\"margin:10px;font-size:15px;\">\n二次審査はミクチャと面接を通して、<br>\n<br>\n<b>\n✨「どれだけ本気でアイドルになりたいのか」<br>\n✨「どれだけ応援されるか」<br>\n✨「どれだけファンを増やせるか」<br>\n✨「どれだけ本気で配信に向き合えるか」\n</b>\n<br>\n<br>\nをチェックする審査イベントです！<br>\n<br>\n配信でのトーク、想い、毎日の積み重ね——<br>\nあなたらしさを届けることが、最終審査への近道！<br>\n<br>\nそしてファンのみなさんの応援が、<br>\n参加者の未来を大きく動かします📣💫\n\n\n<br>\n\n</p><h3 class=\"logo\">二次審査スケジュール</h3>\n<p style=\"margin:10px;font-size:15px;\">\n　<b>前半（ミクチャ）</b><br>\n　07/08(水) 20:00 〜 07/20(月) 22:00<br>\n<br>\n　<b>中間（面接）</b><br>\n　07/21(火）〜 07/26 (日 ) のいずれか<br>\n<br>\n　<b>後半（ミクチャ）</b><br>\n　07/27(月) 18:00 〜 08/09(日) 22:00<br>\n\n\n<br>\n\n</p><h3 class=\"logo\">最終審査進出条件</h3>\n<p style=\"margin:10px;\">\n<br>\n<b>①総合ポイントランキング1〜3位（※1）</b><br>\n<b><font size=\"3\"><font color=\"#FE0083\">✨最終審査進出✨</font>\n</font></b></p>\n\n<br>\n\n<p style=\"margin:10px;\">\n<b>②審査員特別賞（※2）</b><br>\n<b><font size=\"3\"><font color=\"#FE0083\">✨最終審査進出✨</font>\n</font></b></p>\n<br>\n\n<p style=\"margin:10px;font-size:15px;\">\n※1：総合ポイントが同数となった場合は「①ミクチャポイント審査」の上位を優先して選出を行います。<br>\n<br>\n※2：審査員特別賞は、ミクチャ配信や動画投稿内容、面接内容等を総合的に判断して選出いたします。選出者無しとなる場合もございますのであらかじめご了承ください。\n\n\n</p><h3 class=\"logo\">総合ポイント配点</h3>\n\n<center>\n<div style=\"margin:15px;background:#f9f9f9;opacity:0.8;width:90%;text-align:left;padding:5px;font-size:15px;\">\n<center>\n<b><font size=\"3\" color=\"#FE0083\">①ミクチャ”ポイント”審査</font></b>\n</center>\n\n<p style=\"margin:10px;font-size:15px;\">\n◆前半＋後半でのミクチャ配信+動画投稿による獲得ポイント数を競い、ランキングに応じて総合ポイントを付与します。<br>\n<br>\n※例：前半100万ポイント＋後半100万ポイント＝合計200万ポイント獲得（ランキング1位の場合）\n<br>\n→総合ポイント：108pt 獲得\n<br>\n<br>\n\n</p><center>\n<b>\n<table style=\"padding:0.9em 0.9em;margin:10px;font-size:16px;\">\n    <thead>\n        <tr>\n       \n        </tr>\n    </thead>\n    <tbody>\n        <tr>\n            <td>1位：100 pt　　</td>\n            <td>6位：50 pt　　</td>\n        </tr>\n        <tr>\n            <td>2位：90 pt</td>\n            <td>7位：40 pt</td>\n        </tr>\n        <tr>\n            <td>3位：80 pt</td>\n            <td>8位：30 pt</td>\n        </tr>\n        <tr>\n            <td>4位：70 pt</td>\n            <td>9位：20 pt</td>\n        </tr>\n        <tr>\n            <td>5位：60 pt</td>\n            <td>10位〜：10 pt</td>\n        </tr>\n    </tbody>\n</table>\n</b>\n</center>\n\n<p style=\"margin:10px;font-size:15px;\">\n※上記に加えて、ミクチャポイント <b><font color=\"#FE0083\">50万pt達成ごと</font></b> に <b><font color=\"#FE0083\">総合ポイント2pt</font></b> ボーナス付与！\n\n<br>\n\n</p></div>\n</center>\n\n\n<center>\n<div style=\"margin:15px;background:#f9f9f9;opacity:0.8;width:90%;text-align:left;padding:5px;font-size:15px;\">\n\n<center>\n<b><font size=\"3\" color=\"#FE0083\">②ミクチャ”配信時間”審査</font></b>\n</center>\n<p style=\"margin:10px;font-size:15px;\">\n◆前半＋後半でのミクチャ配信時間を競い、ランキングに応じて総合ポイントを付与します。<br>\n<br>\n※例：前半20時間＋後半20時間＝合計40時間（ランキング1位の場合）\n<br>\n→総合ポイント：40pt 獲得\n<br>\n<br>\n\n</p><center>\n<b>\n<table style=\"padding:0.9em 0.9em;margin:10px;font-size:16px;\">\n    <thead>\n        <tr>\n       \n        </tr>\n    </thead>\n    <tbody>\n        <tr>\n            <td>1位：40 pt　　</td>\n            <td>6位：20 pt　　</td>\n        </tr>\n        <tr>\n            <td>2位：36 pt</td>\n            <td>7位：16 pt</td>\n        </tr>\n        <tr>\n            <td>3位：32 pt</td>\n            <td>8位：12 pt</td>\n        </tr>\n        <tr>\n            <td>4位：28 pt</td>\n            <td>9位：8 pt</td>\n        </tr>\n        <tr>\n            <td>5位：24 pt</td>\n            <td>10位〜：4 pt</td>\n        </tr>\n    </tbody>\n</table>\n</b>\n</center>\n\n\n</div>\n</center>\n\n\n<center>\n<div style=\"margin:15px;background:#f9f9f9;opacity:0.8;width:90%;text-align:left;padding:5px;font-size:15px;\">\n\n<center>\n<b><font size=\"3\" color=\"#FE0083\">③ミクチャ”ファン獲得”審査</font></b>\n</center>\n<p style=\"margin:10px;font-size:15px;\">\n◆前半＋後半でのミクチャでのファン増加数を競い、ランキングに応じて総合ポイントを付与します。<br>\n<br>\n※例：前半100人増加＋後半100人増加＝合計200人増加（ランキング1位の場合）\n<br>\n→総合ポイント：40pt 獲得\n<br>\n\n</p><center>\n<b>\n<table style=\"padding:0.9em 0.9em;margin:10px;font-size:16px;\">\n    <thead>\n        <tr>\n       \n        </tr>\n    </thead>\n    <tbody>\n        <tr>\n            <td>1位：40 pt　　</td>\n            <td>6位：20 pt　　</td>\n        </tr>\n        <tr>\n            <td>2位：36 pt</td>\n            <td>7位：16 pt</td>\n        </tr>\n        <tr>\n            <td>3位：32 pt</td>\n            <td>8位：12 pt</td>\n        </tr>\n        <tr>\n            <td>4位：28 pt</td>\n            <td>9位：8 pt</td>\n        </tr>\n        <tr>\n            <td>5位：24 pt</td>\n            <td>10位〜：4 pt</td>\n        </tr>\n    </tbody>\n</table>\n</b>\n</center>\n\n\n</div>\n</center>\n\n\n<center>\n<div style=\"margin:15px;background:#f9f9f9;opacity:0.8;width:90%;text-align:left;padding:5px;font-size:15px;\">\n\n<center>\n<b><font size=\"3\" color=\"#FE0083\">④面接審査</font></b>\n</center>\n<p style=\"margin:10px;font-size:15px;\">\n◆07/21(火）〜 07/26 (日 ) のいずれかにて面接を行い、ランキングに応じて総合ポイントを付与します。<br>\n<br>\n\n</p><center>\n<b>\n<table style=\"padding:0.9em 0.9em;margin:10px;font-size:16px;\">\n    <thead>\n        <tr>\n       \n        </tr>\n    </thead>\n    <tbody>\n        <tr>\n            <td>1位：80 pt　　</td>\n            <td>6位：40 pt　　</td>\n        </tr>\n        <tr>\n            <td>2位：72 pt</td>\n            <td>7位：32 pt</td>\n        </tr>\n        <tr>\n            <td>3位：64 pt</td>\n            <td>8位：24 pt</td>\n        </tr>\n        <tr>\n            <td>4位：56 pt</td>\n            <td>9位：16 pt</td>\n        </tr>\n        <tr>\n            <td>5位：48 pt</td>\n            <td>10位〜：8 pt</td>\n        </tr>\n    </tbody>\n</table>\n</b>\n</center>\n\n\n</div>\n</center>\n\n\n\n<br>\n\n\n<br><center><img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/NIKU/mixch_LOGO.png\" width=\"15%\"></center><br>\n\n</div>\n</div>\n\n<!-- 2タブの中身おわり💡 -->\n\n<!-- 💡3タブの中身はじめ -->\n\n<div id=\"tabView3\" class=\"tabView\">\n<div style=\"background-color:rgba(255,255,255,1);color:#735d65;font-size:15px;\">\n<br>\n<p style=\"margin:10px;font-size:15px;\">\n※下記のランキングは2/22(日)以降【毎日10時ごろ】に更新予定です。\n\n</p><h3 class=\"logo\">ファン増加+配信時間総合ランキング</h3>\n<center>\n<iframe src=\"https://docs.google.com/spreadsheets/d/e/2PACX-1vQ8WLX2qrrY3ER_6XSImYAGYjE09BCAAh9W0ORflXzU7JumfYD-cFWCJh6jYeiCkwStA7OmswVC1jO9/pubhtml?gid=1758631047&amp;single=true&amp;widget=false&amp;chrome=false&amp;headers=false&amp;range=A2:F103\" width=\"95%\" height=\"400px\">\n</iframe>\n</center>\n\n<br>\n<br>\n\n<h3 class=\"logo\">ファン増加ランキング</h3>\n<center>\n<iframe src=\"https://docs.google.com/spreadsheets/d/e/2PACX-1vQ8WLX2qrrY3ER_6XSImYAGYjE09BCAAh9W0ORflXzU7JumfYD-cFWCJh6jYeiCkwStA7OmswVC1jO9/pubhtml?gid=1279662019&amp;single=true&amp;widget=false&amp;chrome=false&amp;headers=false&amp;range=A2:E103\" width=\"95%\" height=\"400px\">\n</iframe>\n</center>\n\n\n<br>\n<br>\n\n<h3 class=\"logo\">配信時間ランキング</h3>\n<center>\n<iframe src=\"https://docs.google.com/spreadsheets/d/e/2PACX-1vQ8WLX2qrrY3ER_6XSImYAGYjE09BCAAh9W0ORflXzU7JumfYD-cFWCJh6jYeiCkwStA7OmswVC1jO9/pubhtml?gid=1777272581&amp;single=true&amp;widget=false&amp;chrome=false&amp;headers=false&amp;range=A2:E95\" width=\"95%\" height=\"400px\">\n</iframe>\n</center>\n\n\n\n\n\n<p></p><br>\n<br><center><img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/NIKU/mixch_LOGO.png\" width=\"15%\"></center>\n\n<br>\n</div>\n</div>\n<!-- 3タブの中身おわり💡 -->\n<!-- 💡4タブの中身はじめ -->\n<div id=\"tabView4\" class=\"tabView\">\n<div style=\"background-color:rgba(255,255,255,1);color:#735d65;font-size:15px;\">\n\n<h3 class=\"logo\">🚨最終合宿審査進出チャンス《拡大》！🚨</h3>\n<p style=\"margin:10px;\">\n<br>\n最終合宿審査への進出条件が<b>【アップデート】</b>され、チャンスが拡大しました！<br>\n\n</p><center>\n<div style=\"margin:5px;background:#fff0f5;opacity:0.8;width:90%;text-align:left;padding:5px;font-size:16px;\">\n<center><b><font color=\"#FF0F6B\">◆最終合宿審査進出条件</font></b></center>\n<p style=\"margin:5px;font-size:15px;\">\n① ミクチャ獲得ポイントランキング<b><font color=\"#FF0F6B\">《1〜2位》</font></b><br>\n② ファン増加数＋配信時間の総合ポイント<b><font color=\"#FF0F6B\">《1〜2位》</font></b><br>\n③ 審査員特別賞<br>\n<br>\n</p><p style=\"margin:5px;font-size:15px;\">\n※新たに<br>\n<b><font color=\"#FF0F6B\">「ミクチャ獲得ポイントランキング2位」<br>\n「ファン増加数＋配信時間 総合ポイント2位」</font></b><br>\nの進出枠が追加決定！<br>\n</p></div>\n</center>\n\n<p style=\"margin:10px;\">\n<br>\nさらに！！！<br>\nオーディション期間中、順位を大きく左右する<br>\n<b>《3本立てゲリライベント》を期間限定</b>で実施！<br>\n<br>\n<b>📈 ゲリライベントでの伸びが、そのまま進出ラインに直結！<br>\n📣 今この瞬間の行動が、運命を変える。</b><br>\n<br>\n最終合宿審査へ進むのは、最後まで諦めずに<b>“動き続けた人”</b>。<br>\n全力の挑戦、ここからが本番です🔥\n<br>\n<br>\n\n</p><h3 class=\"logo\">ゲリラ①｜指定アイテム獲得ランキング特典</h3>\n<p style=\"margin:13px;font-size:15px;\">\n期間中の指定アイテム獲得数ランキングに応じて、<br>\n最終盤で圧倒的な注目を集める豪華特典を付与！<br>\n<br>\n\n</p><center>\n<div style=\"margin:10px;color:#fff;background-image:linear-gradient(-90deg,  #FF0F6B 0%, #FF0F6B);text-align:center;width:70%;border-radius:30px;padding:3px;\">\n<b>ゲリラ①：対象期間</b>\n</div>\n<p style=\"margin:13px;font-size:16px;\">\n<b>2/27(金) 18:00 〜 3/4(水) 22:00</b>\n</p></center>\n\n<br>\n\n<center>\n<div style=\"margin:10px;color:#fff;background-image:linear-gradient(-90deg,  #FF0F6B 0%, #FF0F6B);text-align:center;width:70%;border-radius:30px;padding:3px;\">\n<b>ゲリラ①：特別換算ルール</b>\n</div>\n</center>\n\n\n<p style=\"margin:13px;font-size:15px;\">\n※ゲリラ①では、下記の<b>特別換算ルール</b>を用いて集計を行います。\n<br>\n\n\n</p><center>\n<a href=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/ゲリラ①特別換算ルール.png\" data-lightbox=\"group\" target=\"_blank\" referrerpolicy=\"no-referrer\">\n<img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/ゲリラ①特別換算ルール.png\" width=\"95%\">\n</a>\n<br>\n<font size=\"3\">クリックして拡大</font>\n</center>\n<br>\n<br>\n\n\n<center>\n<div style=\"margin:10px;color:#fff;background-image:linear-gradient(-90deg,  #FF0F6B 0%, #FF0F6B);text-align:center;width:70%;border-radius:30px;padding:3px;\">\n<b>ゲリラ①：限定特典</b>\n</div>\n</center>\n\n\n<p style=\"margin:13px;font-size:15px;\">\n<b><span style=\"background:linear-gradient(transparent 90%, #cb6ce6 0%);\">🥇「ゲリラ①特別換算ルール適用後」の指定アイテム獲得個数1位\n</span></b><br><br>\n\n▶︎▶︎<b><font size=\"3\"><font color=\"#FF0F6B\">ヒロインズ公式Xで紹介！<small>（2026/03/04 追加）</small></font></font></b><br>\n※下記「ヒロインズ公式Xで紹介に関する注意事項」もご確認ください。\n<br>\n<br>\n▶︎▶︎<b><font size=\"3\"><font color=\"#FF0F6B\">最終日ミクチャTOP枠”22時間”掲載！</font></font></b><br>（3/8 00:00-22:00予定）\n</p><br>\n\n\n<p style=\"margin:13px;font-size:15px;\">\n<b><span style=\"background:linear-gradient(transparent 90%, #cb6ce6 0%);\">🥈「ゲリラ①特別換算ルール適用後」の指定アイテム獲得個数2位\n</span></b><br><br>\n\n▶︎▶︎<b><font size=\"3\"><font color=\"#FF0F6B\">ヒロインズ公式Xで紹介！<small>（2026/03/04 追加）</small></font></font></b><br>\n※下記「ヒロインズ公式Xで紹介に関する注意事項」もご確認ください。\n<br>\n<br>\n\n▶︎▶︎<b><font size=\"3\"><font color=\"#FF0F6B\">最終日前日ミクチャTOP枠”12時間”掲載！</font></font></b><br>（3/7 12:00-24:00予定）\n</p><br>\n\n<p style=\"margin:13px;font-size:15px;\">\n<b><span style=\"background:linear-gradient(transparent 90%, #cb6ce6 0%);\">🥉「ゲリラ①特別換算ルール適用後」の指定アイテム獲得個数3位\n</span></b><br><br>\n▶︎▶︎<b><font size=\"3\"><font color=\"#FF0F6B\">最終日前日ミクチャTOP枠”6時間”掲載！</font></font></b><br>（3/7 06:00-12:00予定）\n</p><br>\n\n\n<p style=\"margin:13px;font-size:15px;\">\n<b><span style=\"background:linear-gradient(transparent 90%, #cb6ce6 0%);\">🎖️「ゲリラ①特別換算ルール適用後」の指定アイテム獲得個数 ”300個” 達成者全員\n</span></b><br><br>\n▶︎▶︎<b><font size=\"3\"><font color=\"#FF0F6B\">総合ポイント ”5pt \" 付与</font></font></b><br>\n</p><br>\n\n\n<center>\n<div style=\"margin:5px;background:#fff0f5;opacity:0.8;width:90%;text-align:left;padding:5px;font-size:15px;\">\n<center><b><font color=\"#FF0F6B\">2026/03/04 追記<br>【「ヒロインズ公式Xで紹介」に関する注意事項】</font></b></center>\n<p style=\"margin:5px;font-size:15px;\">\n※受賞者の方には、<b><font color=\"#FF0F6B\">【オーディション運営が指定する写真データ】</font></b>を<b><font color=\"#FF0F6B\">【2026年3月5日（木）23:59まで】</font></b>にご提出いただく必要がございます。<br>\n<br>\n※<b><font color=\"#FF0F6B\">ゲリライベント終了から写真提出までの期間が非常に短くなっております。</font></b>あらかじめスケジュールをご確認のうえ、速やかなご対応をお願いいたします。<br>\n<br>\n※提出いただく写真は、下記条件をすべて満たしている必要がございます。<br>\n<br>\n<b><font color=\"#FF0F6B\">【写真指定条件】<br>\n▼服装<br>\n・白または黒の無地Tシャツ<br>\n・文字／キャラクター／ロゴ等、第三者の著作権を侵害する可能性のあるデザインが入っているものは不可<br><br>\n▼背景<br>\n・白背景<br>\n<br>\n▼画角<br>\n・バストアップ（胸から上が写る構図）<br>\n<br>\n▼撮影方法<br>\n・必ず外カメラで撮影してください（インカメラでの撮影は一切不可）<br>\n・インカメラで撮影された写真は、条件不備として無効扱いとなります</font></b><br>\n<br>\n※上記指定条件を満たさない写真、または期日までに写真のご提出が確認できない場合、ヒロインズ公式Xでのご紹介は実施できかねます。その場合でも、特典の代替対応等は行いませんので、予めご了承ください。<br>\n<br>\n※公式Xへの投稿は2026年3月6日（金）〜3月8日（日）のいずれかを予定しておりますが、投稿時間は運営側の判断により前後する場合がございます。\n</p></div>\n</center>\n<br>\n\n<center>\n<div style=\"margin:5px;background:#fff0f5;opacity:0.8;width:90%;text-align:left;padding:5px;font-size:15px;\">\n<center><b><font color=\"#FF0F6B\">【ゲリラ①：注意事項】</font></b></center>\n<p style=\"margin:5px;font-size:15px;\">\n※特別換算ルール適用後の指定アイテム獲得個数が同数となった場合、ゲリラ①期間中に獲得したポイント上位者を優先して選出いたします。<br>\n※「ゲリラ①特別換算ルール適用後」の指定アイテム獲得個数 ”300個” 達成者は、最終集計時に総合ポイント5pt加算して集計を行います。<br>\n※対象期間中は、配信中の画面右上に「累計獲得数」のカウンターが表示されます。<b>（特別換算ルール適用”前”の個数となりますのでご注意ください）</b><br>\n※5種類目以降はカウンター部分をスクロールすることで確認することができます。\n</p></div>\n</center>\n<br>\n\n\n<h3 class=\"logo\">ゲリラ②｜指定アイテム《ボーナスポイント》</h3>\n<p style=\"margin:13px;font-size:15px;\">\n指定アイテムの累計獲得個数に応じて、<br>\nミクチャ獲得ポイントにボーナスポイントを加算！<br>\n<br>\n\n</p><center>\n<div style=\"margin:10px;color:#fff;background-image:linear-gradient(-90deg,  #9932cc 0%, #9932cc);text-align:center;width:70%;border-radius:30px;padding:3px;\">\n<b>ゲリラ②：対象期間</b>\n</div>\n<p style=\"margin:13px;font-size:16px;\">\n<b>2/27(金) 18:00 〜 3/4(水) 22:00</b>\n</p></center>\n\n<br>\n\n<center>\n<div style=\"margin:10px;color:#fff;background-image:linear-gradient(-90deg,  #9932cc 0%, #9932cc);text-align:center;width:70%;border-radius:30px;padding:3px;\">\n<b>ゲリラ②：ボーナスポイントルール</b>\n</div>\n</center>\n\n<p style=\"margin:13px;font-size:15px;\">\n※ゲリラ②では、対象期間中のみで獲得した<b>「累計獲得数」</b>を元に<b>「ミクチャ獲得ポイント」</b>に加算するボーナスポイントを集計します。<br>\n<br>\n\n\n</p><center>\n<a href=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/ゲリラ②ボーナスポイントルール.png\" data-lightbox=\"group\" target=\"_blank\" referrerpolicy=\"no-referrer\">\n<img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/ゲリラ②ボーナスポイントルール.png\" width=\"95%\">\n</a>\n<br>\n<font size=\"3\">クリックして拡大</font>\n</center>\n<br>\n<br>\n\n<center>\n<div style=\"margin:5px;background:#f7efff;opacity:0.8;width:90%;text-align:left;padding:5px;font-size:15px;\">\n<center><b><font color=\"#9932cc\">【ゲリラ②：注意事項】</font></b></center>\n<p style=\"margin:5px;font-size:15px;\">\n・ボーナスポイントは最終集計時に加算されます。（ランキングには即時反映はございません）<br>\n例：リトルボックスを50個獲得した場合、ボーナスポイント（13,000pt）に関しては最終集計時にボーナスとして加算されます。<br>\n※対象期間中は、配信中の画面右上に「累計獲得数」のカウンターが表示されます。<br>\n※5種類目以降はカウンター部分をスクロールすることで確認することができます。\n</p></div>\n</center>\n<br>\n\n\n<h3 class=\"logo\">ゲリラ③｜配信時間《努力還元》ボーナス</h3>\n<p style=\"margin:13px;font-size:15px;\">\n日々の積み重ねが、最終局面で一気に結果へと変わる努力還元型ボーナスです。<br>\n<br>\n\n</p><center>\n<div style=\"margin:10px;color:#fff;background-image:linear-gradient(-90deg,  #0000cd 0%, #0000cd);text-align:center;width:70%;border-radius:30px;padding:3px;\">\n<b>ゲリラ③：対象期間</b>\n</div>\n<p style=\"margin:13px;font-size:16px;\">\n<b>2/27(金) 18:00 〜 3/5(木) 22:00</b>\n</p></center>\n\n<br>\n\n<center>\n<div style=\"margin:10px;color:#fff;background-image:linear-gradient(-90deg,  #0000cd 0%, #0000cd);text-align:center;width:70%;border-radius:30px;padding:3px;\">\n<b>ゲリラ③：限定特典</b>\n</div>\n</center>\n<p style=\"margin:13px;font-size:15px;\">\n<b><span style=\"background:linear-gradient(transparent 90%, #cb6ce6 0%);\">⏰配信<font color=\"#0000cd\">”35時間以上”</font>達成者全員！</span></b><br><br>\n▶︎▶︎<b><font size=\"3\"><font color=\"#0000cd\">最終日前日 &amp; 最終日</font></font></b>の獲得ポイントが<b><font size=\"3\"><font color=\"#0000cd\">1.5倍</font></font></b><br>\n</p>\n\n<br>\n<center>\n<div style=\"margin:5px;background:#f4f9ff;opacity:0.8;width:90%;text-align:left;padding:5px;font-size:15px;\">\n<center><b><font color=\"#0000cd\">【ゲリラ③：注意事項】</font></b></center>\n<p style=\"margin:5px;font-size:15px;\">\n・対象期間中の累計配信時間に応じて適用されます。<br>\n・倍率はLIVE配信ポイント/動画投稿ポイント両方に適用されます。<br>\n・倍率分の差額ポイントは最終集計時に加算されます。（ランキングには即時反映はございません）<br>\n例：最終日のみで100,000pt獲得した場合、1.5倍分の差額ポイント（50,000pt分）に関しては最終集計時にボーナスとして加算されます。\n</p></div>\n</center>\n<br>\n\n<br><center><img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/NIKU/mixch_LOGO.png\" width=\"15%\"></center>\n<br><br>\n</div>\n</div>\n</div>\n<!-- 4タブの中身おわり💡 -->\n\n\n<br>\n<br>\n\n<!--css start -->\n<style type=\"text/css\">.main-content { max-width: 480px; color: rgb(0, 0, 0); background: url(\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/kanazawa_haikei.png\") center top / 100% repeat rgba(255, 255, 255, 0.5); }\n.tab-content label { display: inline-block; padding: 5px; font-weight: bold; font-size: 15px; color: rgb(253, 125, 188); cursor: pointer; border-radius: 5px 5px 0px 0px; box-sizing: border-box; border-width: 2px 2px medium; border-style: solid solid none; border-color: rgb(253, 125, 188) rgb(253, 125, 188) currentcolor; border-image: initial; background-color: rgba(255, 242, 247, 0.7); }\n.tab-content label:hover { opacity: 0.5; }\n.tab-content input[type=\"radio\"]:checked + label { color: rgb(255, 255, 255); background-color: rgb(253, 125, 188); border-width: 2px 2px medium; border-style: solid solid none; border-color: rgb(253, 125, 188) rgb(253, 125, 188) currentcolor; border-image: initial; }\n.tab-content .tab-box { width: 100%; height: auto; padding: 10px; border-radius: 0px 2px 2px; box-sizing: border-box; border: 2.5px solid rgb(253, 125, 188); }\n.tab-content > .tab-box > div { display: none; }\n.box1 { height: auto; padding: 0px; background-color: rgb(255, 255, 255); color: rgb(0, 0, 0); border: 2.5px solid rgb(254, 0, 131); position: relative; margin: 2em; }\n.box2 { height: auto; padding: 0px; background-color: rgb(255, 255, 255); color: rgb(0, 0, 0); border: 2.5px solid rgb(240, 84, 116); position: relative; margin: 2em; }\n.tab-content > .tab-box > div { display: none; }\n#tab1:checked ~ .tab-box > #tabView1, #tab2:checked ~ .tab-box > #tabView2, #tab3:checked ~ .tab-box > #tabView3, #tab4:checked ~ .tab-box > #tabView4, #tab5:checked ~ .tab-box > #tabView5 { display: block; background-color: rgba(255, 242, 247, 0.2); }\ndiv.content { color: rgb(101, 221, 206); line-height: 1.75; font-size: 15px; margin: 20px 0px; }\n.tab-box h3.logo { margin: 0px 15px 10px; padding: 15px 5px 10px; background-image: linear-gradient(120deg, rgb(223, 74, 143) 10%, rgb(223, 74, 143) 100%); text-shadow: rgb(254, 0, 131) 0px 0px 12px, rgb(254, 0, 131) 0px 0px 4px; color: rgb(255, 255, 255); background-repeat: no-repeat; background-size: 88% 1px; background-position: 0px 100%; line-height: 2em; }\n.tab-box h3.logo::before { background: url(\"https://d2uqarpmf42qy0.cloudfront.net/event/25_hatamura/img/common/mixcha-logo-white-outline-512x512px.png\") center center / contain no-repeat; display: inline-block; margin: 0px 8px 5px 0px; content: \"\"; width: 1.5em; height: 1.5em; vertical-align: bottom; filter: drop-shadow(rgb(254, 0, 131) 0px 0px 1px) drop-shadow(rgb(254, 0, 131) 0px 0px 2px) drop-shadow(rgb(255, 255, 255) 0px 0px 2px); }\n#tabView1, #tabView2, #tabView3, #tabView4, #tabView5 { background-color: rgb(255, 255, 255); }\n.tab-box p { margin: 10px; }\n.box_gold { position: relative; margin: 0.3em; border: 3px solid rgb(101, 221, 206); color: rgb(101, 221, 206); }\n.tab-content input[type=\"radio\"] { display: none; }\ndiv.content ul { padding: 0px 2em 0px 3em; }\ndiv.content table { padding: 5px 2em; }\ndiv.content table tr { line-height: 1.5; }\ndiv.content table tr { vertical-align: bottom; }\ndiv.content table th { font-weight: bold; text-align: left; }\ndiv.button-container { margin: 20px 20px 30px; font-size: 16px; font-weight: bold; text-align: center; }\ndiv.button-container img { display: inline-block; }\n.precaution { line-height: 1.25; color: rgb(96, 96, 96); margin-bottom: 20px; }\ndiv.content div.judges, div.content div.yad-members { padding: 0px 40px; }\ndiv.content div.judges h4 { font-size: 16px; font-weight: bold; border-bottom: 1px solid rgb(128, 128, 128); margin: 40px 20px 10px; }\ndiv.content div.yad-members h4 { font-size: 16px; font-weight: bold; margin: 40px 20px 10px; }\ndiv.content div.judges .portrait, div.content div.yad-members .portrait { text-align: center; }\ndiv.content div.judges .portrait img, div.content div.yad-members .portrait img { width: 160px; display: inline-block; margin: 5px 0px; }\ndiv.content img.footer-logo { width: 20%; margin: 0px auto; padding: 40px 0px; display: block; }\ndiv.content div.yad-members h5 { font-size: 15px; font-weight: bold; margin: 5px 20px 0px; }\ndiv.content a.link-btn, div.content a.link-btn:link, div.content a.link-btn:visited { display: inline-block; padding: 10px 50px; border: 2px solid rgb(255, 168, 203); border-radius: 70px; transition: 0.125s; text-decoration: none; font-size: 15px; font-weight: bold; line-height: 1.5; background-color: rgb(255, 255, 255); text-shadow: rgb(247, 186, 209) 0px 0px 8px, rgb(254, 0, 131) 0px 0px 6px, rgb(254, 0, 131) 0px 0px 4px, rgb(71, 29, 171) 0px 0px 2px, rgb(254, 0, 131) 0px 0px 0.5px; color: rgb(255, 255, 255); }\ndiv.content a.link-btn > span, div.content a.link-btn:link > span, div.content a.link-btn:visited > span { color: rgb(255, 255, 255); transition: 0.125s; font-size: 14px; filter: drop-shadow(rgb(254, 0, 131) 0px 0px 1px) drop-shadow(rgb(254, 0, 131) 0px 0px 2px) drop-shadow(rgb(255, 255, 255) 0px 0px 2px); }\ndiv.content a.link-btn:hover { background-color: rgb(255, 255, 255); color: rgb(255, 255, 255); filter: drop-shadow(rgb(254, 0, 131) 0px 0px 1px) drop-shadow(rgb(254, 0, 131) 0px 0px 2px) drop-shadow(rgb(255, 255, 255) 0px 0px 2px); }\ndiv.content a.link-btn:hover > span { color: rgb(255, 255, 255); filter: drop-shadow(rgb(254, 0, 131) 0px 0px 1px) drop-shadow(rgb(254, 0, 131) 0px 0px 2px) drop-shadow(rgb(255, 255, 255) 0px 0px 2px); }\ndiv.content a.link-btn:active { background-color: rgb(255, 255, 255); box-shadow: rgba(0, 0, 0, 0) 0px 0px 0px; transition: all; filter: drop-shadow(rgb(254, 0, 131) 0px 0px 1px) drop-shadow(rgb(254, 0, 131) 0px 0px 2px) drop-shadow(rgb(255, 255, 255) 0px 0px 2px); }\nstrong { text-align: center; background: linear-gradient(transparent 80%, rgb(178, 17, 149) 80%); }\n.button_p { margin: 10px; padding: 5px; background-color: rgb(101, 221, 206); text-align: center; color: rgb(255, 255, 255); font-size: 15px; font-weight: bold; border-radius: 30px; border: 4px outset rgb(101, 221, 206); }\ndiv.content table { padding: 5px 2em; }\ndiv.content table tr { line-height: 1.5; }\ndiv.content table tr { vertical-align: bottom; }\ndiv.content table th { font-weight: bold; text-align: left; }\ntable { border-collapse: collapse; border: 2px solid rgb(254, 0, 131); }\nth, td { padding: 10px; border: 1px dashed rgb(254, 0, 131); }\nth { background-color: rgb(254, 0, 131); color: white; }\n</style>\n\n<!-- css end -->\n\n</div>\n</div>\n\n</div><div id=\"lightboxOverlay\" class=\"lightboxOverlay\" style=\"display: none;\"></div><div id=\"lightbox\" class=\"lightbox\" style=\"display: none;\"><div class=\"lb-outerContainer\"><div class=\"lb-container\"><img class=\"lb-image\" src=\"\"><div class=\"lb-nav\"><a class=\"lb-prev\" href=\"\"></a><a class=\"lb-next\" href=\"\"></a></div><div class=\"lb-loader\"><a class=\"lb-cancel\"></a></div></div></div><div class=\"lb-dataContainer\"><div class=\"lb-data\"><div class=\"lb-details\"><span class=\"lb-caption\"></span><span class=\"lb-number\"></span></div><div class=\"lb-closeContainer\"><a class=\"lb-close\"></a></div></div></div></div>"
