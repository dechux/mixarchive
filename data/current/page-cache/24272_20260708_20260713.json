  "detailHtml": "<div class=\"content\"><style>*{max-width:100% !important;}*::before{max-width:100% !important;}*::after{max-width:100% !important;};  .cf:after{content:&apos; &apos;;display:block;clear:both;height:0;}.cf{display:inline-block;}.cf{display:block;}body{background:#f8f7f4;font-family:Hiragino Kaku Gothic Pro,Meiryo,MS PGothic,sans-serif;font-size:16px;line-height:1.4;letter-spacing:0.05em;margin:0px;color:#3c3c3c;overflow-y:hidden;overflow-x:hidden;padding:0px 5px;}img{vertical-align:bottom;border:none;outline:none;}a,.text-link{text-decoration:none;outline:none;color:#ef9500;cursor:pointer;}a:hover,.text-link:hover{text-decoration:underline;}input,select,option,textarea{font-family:Hiragino Kaku Gothic Pro,Meiryo,MS PGothic,sans-serif;}.center{text-align:center;}.right{text-align:right;}.button-green{color:#fff;display:block;width:100%;box-sizing:border-box;padding:10px 0 9px 0;margin:0 auto;cursor:pointer;font-size:15px;font-weight:bold;text-align:center;border-radius:3px;-moz-border-radius:3px;-webkit-border-radius:3px;background-color:#65b721;background-image:-webkit-gradient(\n      linear,left top,left bottom,from(#6ac023),to(#65b721)\n    );background-image:-webkit-linear-gradient(top,#6ac023,#65b721);background-image:-moz-linear-gradient(top,#6ac023,#65b721);background-image:-o-linear-gradient(top,#6ac023,#65b721);background-image:linear-gradient(top,#6ac023,#65b721);border:solid 1px #61bc14;text-shadow:0 1px 1px #135e00;box-shadow:0 3px 0 #467f17;}.button-green:hover{text-decoration:none;background:#84d933;}.button-green-s{color:#fff;box-sizing:border-box;cursor:pointer;font-weight:bold;text-align:center;border-radius:3px;-moz-border-radius:3px;-webkit-border-radius:3px;background-color:#65b721;background-image:-webkit-gradient(\n      linear,left top,left bottom,from(#6ac023),to(#65b721)\n    );background-image:-webkit-linear-gradient(top,#6ac023,#65b721);background-image:-moz-linear-gradient(top,#6ac023,#65b721);background-image:-o-linear-gradient(top,#6ac023,#65b721);background-image:linear-gradient(top,#6ac023,#65b721);text-shadow:0 1px 1px #135e00;display:inline-block;font-size:16px;padding:8px 11px 7px 11px;margin:0;width:auto;border:solid 1px #61bc14;box-shadow:0 3px 0 #467f17;}.button-green-s:hover{text-decoration:none;background:#84d933;}.content{background:#fff;margin:0 0 20px 0;padding:0 0 1px 0;box-shadow:0 1px 1px #ccc;}.content p{padding:0 10px;margin:0 0 10px 0;}.content h1{display:none;}.content h2{font-size:16px;background:#f5f5f5;border-left:solid 8px #cece2b;padding:8px 0 8px 8px;}.content h3{padding:0 0 0 5px;margin:0;}.menu{background-color:#333;padding:5px 30px;color:white;width:100%;}</style><p>\n<style>h1 { display: none; }\n</style>\n</p><div class=\"main-content\" style=\"max-width:480px;margin:0 auto;\">\n<center>\n<img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/KV_tigers_mixch.png\" width=\"100%\">\n</center>\n<!-- <center><img src=\"https://d2uqarpmf42qy0.cloudfront.net/torte/event/18869/banner.png?1732066674\" width=\"100%\"></center> --><p></p>\n\n<!-- tab list start -->\n\n<div class=\"tab-content\">\n<input type=\"radio\" id=\"tab1\" name=\"tab\">\n<label for=\"tab1\">EVENT</label>\n<input type=\"radio\" id=\"tab2\" name=\"tab\" checked=\"\">\n<label for=\"tab2\">のぼりモデルオーディション</label>\n<!--\n<input type=\"radio\" id=\"tab3\" name=\"tab\">\n<label for=\"tab3\">GUERRILLA</label>\n-->\n<!-- tab list end -->\n\n<!-- tab1 start -->\n<div class=\"tab-box\">\n<div id=\"tabView1\">\n<div class=\"box1\">\n<h3 class=\"logo\">　BIG CHANCE　</h3>\n<br>\n<center>\n<img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/hanshin_main.png\" width=\"90%\">\n</center><br>\n<!-- ミクチャDAY訴求 -->\n<div style=\"margin:18px;padding:14px;background:#000;border:3px solid #FFE600;border-radius:16px;text-align:center;box-shadow:0 6px 0 #FFE600;color:#fff;\">\n\n  <div class=\"blink\" style=\"display:inline-block;background:#FFE600;color:#000;font-weight:bold;padding:3px 10px;border-radius:999px;font-size:20px;margin-bottom:6px;\">\n    ⚾ BIG CHANCE\n  </div>\n<br>\n\n<div style=\"margin:16px;padding:8px;border:3px solid #000;border-radius:20px;background:rgba(255,255,255,0.85);text-align:center;box-shadow:0 5px 0 #000;backdrop-filter:blur(2px);\">\n<br>\n<p style=\"font-size:16px;color:#000;font-weight:bold;line-height:1.6;\">\n<span style=\"display:inline-block;background:#FFE600;color:#000;padding:5px 10px;border-radius:999px;font-size:15px;margin-bottom:6px;\">\n    JERA セントラル・リーグ公式戦<br>（1軍公式戦）</span><br>\n    <span style=\"font-size:15px;\">2026年8月18日(火)</span><br><br>\n    阪神タイガース<br>\n    VS<br>\n    東京ヤクルトスワローズ<br>\n　<br>\n　<small>@京セラドーム大阪</small>\n  </p></div>\n<br>\n<br>\n\nミクチャがゲームスポンサーとなる<br>\n<b><font size=\"3\">『ミクチャDAY』</font></b>を開催！\n<br>\n<br>    \n<span style=\"background:linear-gradient(transparent 75%, rgba(255,230,0,0.6) 0%);\"><b>「始球式」投球権</b></span>をはじめ<br>\n<span style=\"background:linear-gradient(transparent 75%, rgba(255,230,0,0.6) 0%);\">\n<b>場外のぼり掲載<br>\n場外シート広告モデル掲載<br>\n球場内ビジョンモデル掲載<br>\nうちわモデル掲載<br>\n贈呈式登壇<br>\nイベント間イベント参加\n</b></span>\n<br>\nなどなど......<br><br>\n  <span style=\"background:linear-gradient(transparent 75%, rgba(255,230,0,0.6) 0%);\"><b>超！豪華特典が盛りだくさん🐯</b></span><br>\n<br>\n<br><big>\nここだけの\"特別\"なチャンス、<br>絶対参加するしかない‼️</big><br><br>\n </div>\n\n<p><br><br>\n</p></div><p></p>\n\n<p></p><p></p>\n\n<div class=\"box1\">\n<h3 class=\"logo mzt\">　ミクチャDAY　</h3>\n<center>\n<img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/KV_tigers_mixch.png\" width=\"85%\">\n</center>\n<br>\n<p style=\"margin:10px;font-size:15px;\">\n<b>日程</b>｜2026年8月18日(火)<br>\n<br>\n<b>球場</b>｜京セラドーム大阪<br>\n<font size=\"3\">〒550-0023 大阪府大阪市西区千代崎3丁目中2−中2−1 [<a href=\"https://maps.app.goo.gl/GBzp5XX2n5yqVFh99\" target=\"_blank\" referrerpolicy=\"no-referrer\">MAP</a>]</font><br>\n<br>\n</p><center>\n<iframe src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2905.426325141294!2d135.4761427!3d34.669280400000005!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x6000e7b24b87684b%3A0x535f75f9161484f1!2z5Lqs44K744Op44OJ44O844Og5aSn6Ziq!5e1!3m2!1sja!2sjp!4v1782409013417!5m2!1sja!2sjp\" width=\"200\" height=\"150\" style=\"border:0;\" allowfullscreen=\"\" loading=\"lazy\" referrerpolicy=\"strict-origin-when-cross-origin\"></iframe>\n</center>\n<br>\n<p style=\"margin:10px;font-size:15px;\">\n<b>対戦</b>｜東京ヤクルトスワローズ戦<br>\n<font size=\"3\">※天災等あった場合は中止となる場合がございます。</font>\n</p></div>\n\n<div class=\"box1\">\n<h3 class=\"logo mzt\">　イベント盛りだくさん！　</h3>\n\n<p style=\"margin:20px;font-size:15px;\">\n<b> 【イベント①】<br>京セラドーム大阪で掲載！ のぼりモデルオーディション</b></p>\n\n<center>\n<img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/banner_のぼりモデル.png\" width=\"90%\">\n</center><br>\n\n<p style=\"margin:10px;font-size:15px;\">\n　<b>■募集</b><br>\n　　07/12(日) 23:59:59 まで<small>（本選中もエントリー可）</small><br>\n<br>\n　<b>■本選</b><br>\n　　07/08(水) 12:00:00 - 07/12(日) 23:59:59</p>\n\n<center>\n<a href=\"https://mixch.tv/e/14704/recruit\" a=\"\" class=\"link-btn\" target=\"_blank\" referrerpolicy=\"no-referrer\">エントリーはこちら</a> \n</center><p></p>\n\n<br>\n<hr style=\"border-top:1px dotted #FF1A00;width:60%;\">\n\n\n<p style=\"margin:20px;font-size:15px;\">\n<b> 【イベント②】<br>京セラドーム大阪で配布！ うちわモデルオーディション</b></p>\n\n<center>\n<img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/banner_うちわモデル.png\" width=\"90%\">\n</center><br>\n\n<p style=\"margin:10px;font-size:15px;\">\n　<b>■募集</b><br>\n　　07/17(金) 23:59:59 まで<small>（本選中もエントリー可）</small><br>\n<br>\n　<b>■本選</b><br>\n　　07/13(月) 12:00:00 - 07/17(金) 23:59:59</p>\n\n<center>\n<a href=\"https://mixch.tv/e/14705/recruit\" a=\"\" class=\"link-btn\" target=\"_blank\" referrerpolicy=\"no-referrer\">エントリーはこちら</a> \n</center><p></p>\n\n\n<br>\n<hr style=\"border-top:1px dotted #FF1A00;width:60%;\">\n\n<p style=\"margin:20px;font-size:15px;\">\n<b> 【イベント③】<br>京セラドーム大阪で投球！始球式投球者決定戦！</b></p>\n\n<center>\n<img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/banner_始球式.png\" width=