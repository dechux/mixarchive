kground-image:-o-linear-gradient(top,#6ac023,#65b721);background-image:linear-gradient(top,#6ac023,#65b721);text-shadow:0 1px 1px #135e00;display:inline-block;font-size:16px;padding:8px 11px 7px 11px;margin:0;width:auto;border:solid 1px #61bc14;box-shadow:0 3px 0 #467f17;}.button-green-s:hover{text-decoration:none;background:#84d933;}.content{background:#fff;margin:0 0 20px 0;padding:0 0 1px 0;box-shadow:0 1px 1px #ccc;}.content p{padding:0 10px;margin:0 0 10px 0;}.content h1{display:none;}.content h2{font-size:16px;background:#f5f5f5;border-left:solid 8px #cece2b;padding:8px 0 8px 8px;}.content h3{padding:0 0 0 5px;margin:0;}.menu{background-color:#333;padding:5px 30px;color:white;width:100%;}</style><p>\n<style>h1 { display: none; }\n</style>\n</p><div class=\"main-content\" style=\"max-width:480px;margin:0 auto;\">\n<!--\n<center>\n<img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/banner1 (73).png\" width=\"100%\" />\n</center>\n-->\n<!-- 💡タブセクションはじめ -->\n<div class=\"tab-content\">\n<input type=\"radio\" id=\"tab1\" name=\"tab\" checked=\"\">\n<label for=\"tab1\">　概要　</label>\n<input type=\"radio\" id=\"tab2\" name=\"tab\">\n<label for=\"tab2\">　スケジュール / 審査方法　</label><p></p>\n\n<!-- タブセクションおわり💡 -->\n\n<!-- 💡1タブの中身はじめ -->\n\n<div class=\"tab-box\">\n<div id=\"tabView1\" class=\"tabView\">\n<div style=\"background-color:rgba(255,255,255,0.6);color:#735d65;font-size:15px;\">\n<h3 class=\"logo\">イベント概要</h3>\n<br>\n<center>\n<img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/tif2026_logo.png\" width=\"80%\">\n</center>\n\n\n<br>\n<center>\n<p style=\"margin:11px;font-size:16px;\">\n世界最大のアイドルフェス<br>\n<b><span style=\"background:linear-gradient(transparent 60%, #ff66cc 0%);\">TOKYO IDOL FESTIVAL 2026</span></b><br>\n7/31(金)、8/1(土)、8/2(日)<br>\nお台場・青海周辺エリアで開催！\n</p></center>\n\n<center>\n<p style=\"margin:11px;font-size:16px;\">\nTIF2026と”大人可愛い”世界観で、注目を集める女性ファッション誌「andGIRL」のコラボ企画！<br>\n<br>\n誌面 / web / SNS等で活躍する<br>\n<b><font color=\"#D12B34\">『ビューティーミューズ』</font></b><br>\nを現役女性アイドルの中から1名決定！<br>\nさらに副賞として<b><font color=\"#D12B34\">『デジタル写真集制作権』</font></b><br>\nもご用意します！\n</p></center>\n\n\n<center>\n<a class=\"link-btn\" href=\"https://official.idolfes.com/s/tif2026/\" target=\"_blank\" referrerpolicy=\"no-referrer\">TIF2026 公式HP</a>\n</center>\n\n\n<br>\n\n<h3 class=\"logo\">ビューティーミューズとは？</h3>\n<center>\n<p style=\"margin:11px;font-size:16px;\">\n<b><font color=\"#D12B34\"><font size=\"4\">『ビューティーミューズ』</font></font></b>は<br>\n今回のコラボ企画で新たに誕生する<br>\n<b><font color=\"#D12B34\"><font size=\"4\">『特別称号』</font></font></b>です！\n</p></center>\n\n<div style=\"padding:3px;margin:15px;border:0.5px solid #D12B34;border-radius:10px;\">\n<center>\n<div style=\"margin:10px;color:#fff;background-image:linear-gradient(-90deg,  #D12B34 0%, #D12B34);text-align:center;width:80%;border-radius:30px;padding:3px;\"><b>主な活動内容（予定）</b></div>\n\n<p style=\"margin:2px;font-size:15px;\">\n<b><font color=\"#D12B34\">活動①『andGIRL』誌面</font></b><br>\n<small>\n1年間、毎号『andGIRL』誌面にご出演いただきます！<br>\n（季刊誌のため、計4号掲載を予定）\n</small><br>\n</p><center>\n<img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/andイメージ.png\" width=\"100%\">\n</center>\n\n<br>\n<b><font color=\"#D12B34\">活動②『andGIRL』web &amp; SNS</font></b><br>\n<small>\nweb記事やSNSを通じて、<br>\nファッションや美容はもちろん、旅行、グルメなど、<br>\nリアルなライフスタイルやトレンドを<br>\nキャッチしてみんなにシェア！</small>\n<br>\n<br>\n</center>\n</div>\n\n\n\n<br>\n<br>\n\n<h3 class=\"logo\">andGIRL</h3>\n<center><img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/21nakaya/IMG_1517%20(1).PNG\" width=\"70%\"></center>\n<p style=\"margin:10px;font-size:15px;\">\nアラサーになっても、仕事ができても、結婚しても、「ガール」な大人たちへ！<br>\n可愛いモノが大好き、自分へのごほうび大好き、オシャレにも遊びにも貪欲でアクティブな、キラキラした大人女子のモチベーションを上げる女性メディア。<br>\n</p><br>\n\n\n<center>\n<div style=\"filter:invert(33%) sepia(35%) saturate(2483%) hue-rotate(334deg) brightness(94%) contrast(90%);\">\n<a href=\"https://www.andgirl.jp/\" target=\"_blank\" referrerpolicy=\"no-referrer\"><img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/35ishimatsu/家素材2.png\" width=\"13%\"></a>\n<a href=\"https://twitter.com/andgirl_jp\" target=\"_blank\" referrerpolicy=\"no-referrer\"><img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/35ishimatsu/新Twitter丸_黒.png\" width=\"13%\"></a>\n<a href=\"https://www.instagram.com/andgirl_jp/?hl=ja\" target=\"_blank\" referrerpolicy=\"no-referrer\"><img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/35ishimatsu/Instagram丸_黒.png\" width=\"13%\"></a></div></center><br><br>\n\n<br>\n\n<h3 class=\"logo\">エントリーアイドル（50音順）</h3>\n<br><table width=\"100%\">\n<tbody><tr><td width=\"50%\">\n\n<center>\n<img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/灯田にじ_パラディーク.png\" alt=\"画像\" onselectstart=\"return false;\" onmousedown=\"return false;\" oncontextmenu=\"return false;\" width=\"95%\">\n<br><br>\n<font size=\"3\"><b>灯田にじ</b></font><br>\n<small>パラディーク</small><br>\n<a href=\"https://x.com/para_niji\" target=\"_blank\" referrerpolicy=\"no-referrer\"><img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/x_gray.png\" width=\"28%\"></a>\n<a href=\"https://www.tiktok.com/@para_niji\" target=\"_blank\" referrerpolicy=\"no-referrer\"><img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/tiktok_gray.png\" width=\"28%\"></a>\n<br>\n\n\n</center>\n\n\n</td>\n\n<td width=\"50%\">\n\n<center>\n<img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/大園奈美_Sepiacode.png\" alt=\"画像\" onselectstart=\"return false;\" onmousedown=\"return false;\" oncontextmenu=\"return false;\" width=\"95%\">\n<br><br>\n<font size=\"3\"><b>大園奈美</b></font><br>\n<small>Sepiacode</small><br>\n<a href=\"https://x.com/nami01_22\" target=\"_blank\" referrerpolicy=\"no-referrer\"><img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/x_gray.png\" width=\"28%\"></a>\n<br>\n\n</center>\n\n</td>\n</tr></tbody></table>\n\n<br><table width=\"100%\">\n<tbody><tr><td width=\"50%\">\n\n<center>\n<img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/02_尾上美月_すべての瞬間は君だった。.png\