members .portrait img { width: 160px; display: inline-block; margin: 5px 0px; }\ndiv.content img.footer-logo { width: 20%; margin: 0px auto; padding: 40px 0px; display: block; }\ndiv.content div.yad-members h5 { font-size: 15px; font-weight: bold; margin: 5px 20px 0px; }\ndiv.content a.link-btn, div.content a.link-btn:link, div.content a.link-btn:visited { margin: 5px 0px; display: inline-block; padding: 5px 10px; border: 2px solid rgb(184, 22, 73); border-radius: 70px; transition: 0.125s; text-decoration: none; font-size: 15px; font-weight: bold; line-height: 1.5; color: rgb(184, 22, 73); }\ndiv.content a.link-btn > span, div.content a.link-btn:link > span, div.content a.link-btn:visited > span { color: rgb(184, 22, 73); transition: 0.125s; font-size: 16px; }\ndiv.content a.link-btn:hover { background-color: rgb(184, 22, 73); color: rgb(255, 255, 255); }\ndiv.content a.link-btn:hover > span { color: rgb(255, 255, 255); }\ndiv.content a.link-btn:active { background-color: rgb(184, 22, 73); box-shadow: rgba(0, 0, 0, 0) 0px 0px 0px; transition: all; }\n.box { padding: 3px 0px; background: rgba(255, 255, 255, 0.82); border: 2px solid rgb(17, 17, 17); margin: 10px 5px 30px; border-radius: 4px; backdrop-filter: blur(2px); }\n.box1 { padding: 10px; }\n.inline-block_test { display: inline-block; padding: 5px; height: 90px; border: 3px solid rgb(135, 206, 235); }\n.point { color: rgb(184, 22, 73); font-weight: bold; font-size: 14px; }\n.gradbox { color: rgb(255, 255, 255); width: 70%; border-radius: 30px; height: auto; background-image: linear-gradient(97deg, rgb(184, 22, 73) 0%, rgb(232, 114, 124) 50%, rgb(184, 22, 73) 100%); font-weight: bold; }\n.gradboxinner { padding: 1%; border-radius: 30px; }\n.ranking { height: 95px; text-align: center; background-image: url(\"https://d2uqarpmf42qy0.cloudfront.net/event/23uchiyama/月柱冠.png\"); background-size: contain; background-position: center center; background-repeat: no-repeat; position: relative; }\n.ranking_item { position: absolute; top: 50%; left: 50%; transform: translateY(-50%) translateX(-50%); padding: 20px; font-size: 15px; font-weight: bold; }\n</style>\n\n<!-- CSSセクションおわり💡 -->\n\n<p></p></div>\n</div>\n</div><p></p>\n</div>"
}