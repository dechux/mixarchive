  "detailHtml": "<div class=\"content\"><style>*{max-width:100% !important;}*::before{max-width:100% !important;}*::after{max-width:100% !important;};  .cf:after{content:&apos; &apos;;display:block;clear:both;height:0;}.cf{display:inline-block;}.cf{display:block;}body{background:#f8f7f4;font-family:Hiragino Kaku Gothic Pro,Meiryo,MS PGothic,sans-serif;font-size:16px;line-height:1.4;letter-spacing:0.05em;margin:0px;color:#3c3c3c;overflow-y:hidden;overflow-x:hidden;padding:0px 5px;}img{vertical-align:bottom;border:none;outline:none;}a,.text-link{text-decoration:none;outline:none;color:#ef9500;cursor:pointer;}a:hover,.text-link:hover{text-decoration:underline;}input,select,option,textarea{font-family:Hiragino Kaku Gothic Pro,Meiryo,MS PGothic,sans-serif;}.center{text-align:center;}.right{text-align:right;}.button-green{color:#fff;display:block;width:100%;box-sizing:border-box;padding:10px 0 9px 0;margin:0 auto;cursor:pointer;font-size:15px;font-weight:bold;text-align:center;border-radius:3px;-moz-border-radius:3px;-webkit-border-radius:3px;background-color:#65b721;background-image:-webkit-gradient(\n      linear,left top,left bottom,from(#6ac023),to(#65b721)\n    );background-image:-webkit-linear-gradient(top,#6ac023,#65b721);background-image:-moz-linear-gradient(top,#6ac023,#65b721);background-image:-o-linear-gradient(top,#6ac023,#65b721);background-image:linear-gradient(top,#6ac023,#65b721);border:solid 1px #61bc14;text-shadow:0 1px 1px #135e00;box-shadow:0 3px 0 #467f17;}.button-green:hover{text-decoration:none;background:#84d933;}.button-green-s{color:#fff;box-sizing:border-box;cursor:pointer;font-weight:bold;text-align:center;border-radius:3px;-moz-border-radius:3px;-webkit-border-radius:3px;background-color:#65b721;background-image:-webkit-gradient(\n      linear,left top,left bottom,from(#6ac023),to(#65b721)\n    );background-image:-webkit-linear-gradient(top,#6ac023,#65b721);background-image:-moz-linear-gradient(top,#6ac023,#65b721);background-image:-o-linear-gradient(top,#6ac023,#65b721);background-image:linear-gradient(top,#6ac023,#65b721);text-shadow:0 1px 1px #135e00;display:inline-block;font-size:16px;padding:8px 11px 7px 11px;margin:0;width:auto;border:solid 1px #61bc14;box-shadow:0 3px 0 #467f17;}.button-green-s:hover{text-decoration:none;background:#84d933;}.content{background:#fff;margin:0 0 20px 0;padding:0 0 1px 0;box-shadow:0 1px 1px #ccc;}.content p{padding:0 10px;margin:0 0 10px 0;}.content h1{display:none;}.content h2{font-size:16px;background:#f5f5f5;border-left:solid 8px #cece2b;padding:8px 0 8px 8px;}.content h3{padding:0 0 0 5px;margin:0;}.menu{background-color:#333;padding:5px 30px;color:white;width:100%;}</style><p>\n<style>h1 { display: none; }\n</style>\n</p><div class=\"main-content\" style=\"max-width:480px;margin:0 auto;\">\n<br>\n<!-- 💡タブセクションはじめ -->\n<div class=\"tab-content\">\n<input type=\"radio\" id=\"tab1\" name=\"tab\" checked=\"\">\n<label for=\"tab1\">　概要　</label>\n<input type=\"radio\" id=\"tab2\" name=\"tab\">\n<label for=\"tab2\">　スケジュール / 審査方法　</label><p></p>\n\n<!-- タブセクションおわり💡 -->\n\n<!-- 💡1タブの中身はじめ -->\n\n<div class=\"tab-box\">\n<div id=\"tabView1\" class=\"tabView\">\n<div style=\"background-color:rgba(255,255,255,0.6);color:#735d65;font-size:15px;\">\n<h3 class=\"logo\">イベント概要</h3>\n<br>\n<center>\n<img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/tif2026_logo.png\" width=\"80%\">\n</center>\n\n\n<br>\n<center>\n<p style=\"margin:11px;font-size:16px;\">\n世界最大のアイドルフェス<br>\n<b><span style=\"background:linear-gradient(transparent 60%, #ff66cc 0%);\">TOKYO IDOL FESTIVAL 2026</span></b><br>\n7/31(金)、8/1(土)、8/2(日)<br>\nお台場・青海周辺エリアで開催！\n</p></center>\n\n<center>\n<p style=\"margin:11px;font-size:16px;\">\nTIF2026と縦型ショートドラマアプリ「タテドラ」のコラボ企画！<br>\n<br>\nタテドラで配信されるドラマ<b>『旦那の浮気相手とLINE友達になってみた』</b>への出演権をかけた現役女性アイドル限定オーディションを開催！\n</p></center>\n\n\n<center>\n<a class=\"link-btn\" href=\"https://official.idolfes.com/s/tif2026/\" target=\"_blank\" referrerpolicy=\"no-referrer\">TIF2026 公式HP</a>\n</center>\n\n\n<br>\n\n<h3 class=\"logo\">タテドラ新作ドラマ『旦那の浮気相手とLINE友達になってみた』</h3>\n<center><br>\n<img class=\"image-round\" src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/ogp_linetomodachi.webp\" width=\"95%\"><br>\n</center>\n<center>\n<p style=\"margin:11px;font-size:16px;\">\nSNSに投稿された実話をもとに、<br>\nLINEマンガで話題を集めた<br>\n<b><font color=\"#0096DF\">『旦那の浮気相手とLINE友達になってみた』</font></b><small>（KADOKAWA刊）</small>が、<br>\n「タテドラ」オリジナルドラマ化！<br>\n<br>\n主演 <b><font color=\"#0096DF\">渡邉美穂</font></b>さん、その夫役には<b><font color=\"#0096DF\">さらば青春の光・東ブクロ</font></b>さんが決定！<br>\n<br>\n初秋公開予定！\n</p></center>\n<center>\n<a class=\"link-btn\" href=\"https://tated.tv/linetomodachi/\" target=\"_blank\" referrerpolicy=\"no-referrer\">『旦那の浮気相手とLINE友達になってみた』公式サイト</a>\n</center>\n<br>\n<br>\n\n<h3 class=\"logo\">タテドラとは？</h3>\n<center><br>\n<img class=\"image-round\" src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/タテドラlogo.png\" width=\"70%\">\n</center>\n<br>\n<br>\n<p style=\"margin:10px;font-size:15px;\">\n1話1～2分でサクッと楽しめる縦型ショート動画配信アプリ。<br>\n登録不要で、豊富なラインナップからあなたのお気に入り作品が見放題！<br>\n<br>\n海外の人気作から、タテドラだけのオリジナルコンテンツも。恋愛、サスペンス、都市伝説など、多彩なジャンルが勢ぞろいです！<br>\n<br>\nタテドラから、あなたの毎日に1分で感動のひとときをお届けします。</p>\n<center>\n<a class=\"link-btn\" href=\"https://www.tated.tv/\" target=\"_blank\" referrerpolicy=\"no-referrer\">タテドラ 公式サイト</a>\n</center>\n\n<center>\n<a class=\"link-btn\" href=\"https://www.tiktok.com/@tated.tv\" target=\"_blank\" referrerpolicy=\"no-referrer\">タテドラ 公式TikTok</a>\n</center>\n\n<br>\n\n<h3 class=\"logo\">エントリー条件</h3>\n<p style=\"margin:10px;font-size:15px;\">\n年齢18歳以上の現役女性アイドルのみ参加可能です。<br>\n<b>※TIF2026に出演しない方でもエントリー可能です。</b><br>\n<br>\n※その他詳細は公式LINEにてお問い合わせください。<br>\n<br>\n<br>\n\n\n</p><h3 class=\"logo\">エントリーアイドル（50音順）</h3>\n<br><table width=\"100%\">\n<tbody><tr><td width=\"50%\">\n\n<center>\n<img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/01_葵野歌音_Sepiacode.png\" alt=\"画像\" onselectstart=\"return false;\" onmousedown=\"return false;\" oncontextmenu=\"return false;\" width=\"95%\">\n<br><br>\n<font size=\"3\"><b>葵野歌音</b></font><br>\n<small>Sepiacode</small><br>\n<a href=\"https://x.com/aono_kanon\" target=\"_blank\" referrerpolicy=\"no-referrer\"><img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/x_gray.png\" width=\"28%\"></a>\n<br>\n\n\n</center>\n\n\n</td>\n\n<td width=\"50%\">\n\n<center>\n<img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/02_薄倉りな_myojou.png\" alt=\"画像\" onselectstart=\"return false;\" onmousedown=\"return false;\" oncontextmenu=\"return false;\" width=\"95%\">\n<br><br>\n<font size=\"3\"><b>薄倉りな</b></font><br>\n<small>myojou</small><br>\n<a href=\"https://x.com/myojou_usukura\" target=\"_blank\" referrerpolicy=\"no-referrer\"><img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/x_gray.png\" width=\"28%\"></a>\n<br>\n\n</center>\n\n</td>\n</tr></tbody></table>\n\n<br><table width=\"100%\">\n<tbody><tr><td width=\"50%\">\n\n<center>\n<img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/03_恋鈴かさね_すべての瞬間は君だった。.png\" alt=\"画像\" onselectstart=\"return false;\" onmousedown=\"return false;\" oncontextmenu=\"return false;\" width=\"95%\">\n<br><br>\n<font size=\"3\"><b>恋鈴かさね</b></font><br>\n<small>すべての瞬間は君だった。</small><br>\n<a href=\"https://x.com/kosuzu_kasane\" target=\"_blank\" referrerpolicy=\"no-referrer\"><img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/x_gray.png\" width=\"28%\"></a>\n<a href=\"https://www.instagram.com/kosuzu_kasane_/\" target=\"_blank\" referrerpolicy=\"no-referrer\"><img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/instagram_gray.png\" width=\"28%\"></a>\n<a href=\"https://www.tiktok.com/@kosuzu_kasane\" target=\"_blank\" referrerpolicy=\"no-referrer\"><img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/tiktok_gray.png\" width=\"28%\"></a>\n<br>\n\n</center>\n\n\n\n</td>\n\n<td width=\"50%\">\n\n<center>\n<img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/ラフラフ_saito.png\" alt=\"画像\" onselectstart=\"return false;\" onmousedown=\"return false;\" oncontextmenu=\"return false;\" width=\"95%\">\n<br><br>\n<font size=\"3\"><b>齋藤有紗</b></font><br>\n<small>ラフ×ラフ</small><br>\n<a href=\"https://x.com/saito_arisa_\" target=\"_blank\" referrerpolicy=\"no-referrer\"><img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/x_gray.png\" width=\"28%\"></a>\n<a href=\"https://www.instagram.com/saito_arisa_/\" target=\"_blank\" referrerpolicy=\"no-referrer\"><img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/instagram_gray.png\" width=\"28%\"></a>\n<a href=\"https://www.tiktok.com/@saito_arisa_\" target=\"_blank\" referrerpolicy=\"no-referrer\"><img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/tiktok_gray.png\" width=\"28%\"></a>\n<br>\n\n</center>\n\n\n</td>\n</tr></tbody></table>\n\n<br><table width=\"100%\">\n<tbody><tr><td width=\"50%\">\n\n<center>\n<img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/05_白石あお_あいあるちゅーん.png\" alt=\"画像\" onselectstart=\"return false;\" onmousedown=\"return false;\" oncontextmenu=\"return false;\" width=\"95%\">\n<br><br>\n<font size=\"3\"><b>白石あお</b></font><br>\n<small>あいあるちゅーん</small><br>\n<a href=\"https://x.com/aoao___c\" target=\"_blank\" referrerpolicy=\"no-referrer\"><img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/x_gray.png\" width=\"28%\"></a>\n<a href=\"https://www.instagram.com/aoao__c\" target=\"_blank\" referrerpolicy=\"no-referrer\"><img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/instagram_gray.png\" width=\"28%\"></a>\n<a href=\"https://www.tiktok.com/@o_chaa_\" target=\"_blank\" referrerpolicy=\"no-referrer\"><img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/tiktok_gray.png\" width=\"28%\"></a>\n<br>\n\n\n</center>\n\n\n</td>\n\n<td width=\"50%\">\n\n<center>\n<img src=\"https://d2uqarpmf42qy0.cloudfront.net/event/41haba/06_須賀美月_Sepiacode.png\" alt=\"画像\" onselectstart=\"return false;\" onmousedown=\"return false;\" oncontextmenu=\"retur