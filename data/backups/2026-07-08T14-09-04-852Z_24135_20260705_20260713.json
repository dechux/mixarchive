a(212, 175, 55, 0.28) 0px 5px 14px; }\n.second-reward { background: linear-gradient(135deg, rgb(255, 255, 255) 0%, rgb(238, 241, 245) 60%, rgb(212, 218, 227) 100%); border: 2px solid rgb(174, 183, 196); box-shadow: rgba(120, 130, 150, 0.18) 0px 4px 12px; }\n.third-reward { background: linear-gradient(135deg, rgb(255, 247, 239) 0%, rgb(242, 192, 138) 58%, rgb(196, 122, 50) 100%); border: 2px solid rgb(184, 107, 43); box-shadow: rgba(184, 107, 43, 0.18) 0px 4px 12px; }\n.reward-title { color: rgb(255, 255, 255); display: inline-block; padding: 6px 22px; border-radius: 20px; font-weight: bold; font-size: 16px; margin-bottom: 10px; }\n.gold-title { background: linear-gradient(135deg, rgb(212, 175, 55), rgb(247, 215, 116), rgb(184, 134, 11)); color: rgb(74, 48, 0); box-shadow: rgba(212, 175, 55, 0.32) 0px 3px 8px; }\n.silver-title { background: linear-gradient(135deg, rgb(247, 247, 247), rgb(174, 183, 196), rgb(127, 140, 141)); color: rgb(38, 48, 64); }\n.bronze-title { background: linear-gradient(135deg, rgb(232, 164, 92), rgb(184, 107, 43), rgb(122, 63, 18)); color: rgb(255, 255, 255); }\n.reward-price { font-size: 26px; font-weight: 900; }\n.gold-price { color: rgb(184, 134, 11); text-shadow: rgb(255, 255, 255) 1px 1px 0px; }\n.silver-price { color: rgb(95, 107, 122); text-shadow: rgb(255, 255, 255) 1px 1px 0px; }\n.bronze-price { color: rgb(138, 70, 24); text-shadow: rgb(255, 255, 255) 1px 1px 0px; }\n.team-reward-list h4 { margin: 10px 0px 5px; font-size: 16px; font-weight: bold; }\n.team-reward-list p { margin: 0px; font-size: 16px; }\n.tab-content { margin: 0px 10px; display: flex; flex-wrap: wrap; align-items: flex-end; }\n.tab-content input[type=\"radio\"] { display: none; }\n.tab-content label { display: flex; align-items: center; justify-content: center; flex: 1 1 0px; min-width: 0px; text-align: center; padding: 12px 0px; font-weight: bold; font-size: 15px; line-height: 1.2; color: rgb(20, 45, 255); background-color: rgb(255, 255, 255); cursor: pointer; border-radius: 15px 15px 0px 0px; box-sizing: border-box; border-width: 2px 2px medium; border-style: solid solid none; border-color: rgb(215, 222, 252) rgb(215, 222, 252) currentcolor; border-image: initial; margin: 0px 0px -2px; transition: 0.3s; white-space: nowrap; }\n.tab-content input[type=\"radio\"]:checked + label { color: rgb(255, 255, 255); background: linear-gradient(rgb(20, 45, 255), rgb(212, 20, 216)); border-width: 2px 2px medium; border-style: solid solid none; border-color: rgb(20, 45, 255) rgb(20, 45, 255) currentcolor; border-image: initial; }\n.tab-content .tab-box { width: 100%; height: auto; box-sizing: border-box; font-size: 16px; }\n.tab-content > .tab-box > div { display: none; }\n#tab1:checked ~ .tab-box > #tabView1, #tab2:checked ~ .tab-box > #tabView2, #tab3:checked ~ .tab-box > #tabView3 { display: block; animation: 0.4s ease 0s 1 normal none running fadeIn; }\n@keyframes fadeIn { \n  0% { opacity: 0; transform: translateY(5px); }\n  100% { opacity: 1; transform: translateY(0px); }\n}\n</style><p></p>\n</div>"
